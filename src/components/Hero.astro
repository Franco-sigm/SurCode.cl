---
---

<section id="inicio" class="relative min-h-screen flex items-center pt-32 pb-24 overflow-hidden">
  <!-- Fondo degradado: navy oscuro (izq) -> azul brillante (der) -->
  <div class="absolute inset-0 z-0 pointer-events-none">
    <div class="absolute inset-0 bg-gradient-to-br from-[#04101f] via-[#06203f] to-[#0a4d8f]"></div>

    <!-- Patrón radial sutil -->
    <div
      class="absolute inset-0 opacity-[0.12]"
      style="background-image: repeating-radial-gradient(circle at center, transparent 0, transparent 40px, #334155 41px, #334155 42px);"
    ></div>

    <!-- Imágenes translúcidas (lado derecho): se alternan con crossfade, se funden con el fondo -->
    <div class="absolute inset-y-0 right-0 w-[62%] hidden lg:block">
      <img src="/servicios/shield/1.webp" alt="" loading="eager" decoding="async" class="hero-img is-current" />
      <img src="/servicios/automation/1.webp" alt="" loading="lazy" decoding="async" class="hero-img" />
      <img src="/servicios/automation/3.webp" alt="" loading="lazy" decoding="async" class="hero-img" />
      <!-- Fundido vertical para integrar con navbar (arriba) y la sección siguiente (abajo) -->
      <div class="absolute inset-0" style="background: linear-gradient(180deg, #04101f 0%, transparent 24%, transparent 68%, #04101f 100%);"></div>
    </div>

    <!-- Glow de acento (flotando suavemente) -->
    <div class="absolute top-1/3 right-0 w-[700px] h-[500px] bg-cyan-500/20 rounded-full blur-[160px] animate-float-slow"></div>
    <div class="absolute bottom-0 left-0 w-[600px] h-[400px] bg-emerald-500/10 rounded-full blur-[160px] animate-float-slower"></div>

    <!-- Difuminado hacia el contenido siguiente -->
    <div class="absolute inset-x-0 bottom-0 h-48 bg-gradient-to-b from-transparent to-[#04101f]"></div>
  </div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="max-w-3xl">

      <!-- Titular: identidad de marca -->
      <h1 class="reveal reveal-2 font-sn text-5xl sm:text-6xl lg:text-7xl xl:text-8xl font-extrabold -tracking-[0.02em] leading-[1.0] text-white">
        Software <span class="text-[#62d84e]">Factory</span>
      </h1>

      <!-- Bajada: la propuesta -->
      <p class="font-sn mt-5 text-1xl sm:text-2xl lg:text-3xl font-extrabold -tracking-[0.02em] leading-[1.12]">
        <span class="block text-white reveal reveal-3">Soluciones a medida,</span>
        <span class="block text-[#62d84e] reveal reveal-3">automatización e IA</span>
        <span class="block text-white reveal reveal-3">para tu empresa.</span>
      </p>



      <!-- CTAs -->
      <div class="reveal reveal-4 flex flex-col sm:flex-row gap-4 mt-9">
        <a href="/contacto"
           class="inline-flex items-center justify-center px-8 h-14 rounded-full bg-[#62d84e] text-[#04101f] font-bold text-sm transition-all hover:bg-[#74e85f] hover:scale-105 shadow-[0_10px_40px_rgba(98,216,78,0.35)]">
          Solicitar propuesta
        </a>
        <a href="#servicios"
           class="inline-flex items-center justify-center px-8 h-14 rounded-full border-2 border-[#62d84e] text-white font-bold text-sm transition-all hover:bg-[#62d84e]/10">
          Ver servicios
        </a>
      </div>

    </div>
  </div>
</section>

<style>
  /* Tipografía redondeada estilo ServiceNow (Gilroy) -> Poppins como alternativa libre */
  .font-sn {
    font-family: 'Poppins', 'Geist', system-ui, sans-serif;
  }

  /* Imágenes del hero: translúcidas, monocromáticas y con crossfade entre sí */
  .hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    filter: grayscale(1);
    transition: opacity 2s ease;
    -webkit-mask-image: linear-gradient(90deg, transparent 0%, rgba(0,0,0,.35) 32%, #000 72%);
    mask-image: linear-gradient(90deg, transparent 0%, rgba(0,0,0,.35) 32%, #000 72%);
  }
  .hero-img.is-current { opacity: 0.28; }

  /* Entrada: aparecen subiendo con fade, de forma escalonada */
  @keyframes reveal-up {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .reveal {
    opacity: 0;
    animation: reveal-up 0.8s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  .reveal-1 { animation-delay: 0.10s; }
  .reveal-2 { animation-delay: 0.22s; }
  .reveal-3 { animation-delay: 0.40s; }
  .reveal-4 { animation-delay: 0.55s; }
  .reveal-5 { animation-delay: 0.70s; }

  /* Glows del fondo flotando suavemente para dar profundidad */
  @keyframes float-a {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50%      { transform: translate(-30px, 20px) scale(1.08); }
  }
  @keyframes float-b {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50%      { transform: translate(25px, -25px) scale(1.06); }
  }
  .animate-float-slow   { animation: float-a 12s ease-in-out infinite; }
  .animate-float-slower { animation: float-b 16s ease-in-out infinite; }

  /* Accesibilidad: sin movimiento si el usuario lo prefiere */
  @media (prefers-reduced-motion: reduce) {
    .reveal { opacity: 1; animation: none; }
    .animate-float-slow,
    .animate-float-slower { animation: none; }
    .hero-img { transition: none; }
  }
</style>

<script>
  // Crossfade entre las imágenes translúcidas del hero
  const heroImgs = Array.from(document.querySelectorAll<HTMLElement>('#inicio .hero-img'));
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (heroImgs.length > 1 && !reduceMotion) {
    let i = 0;
    setInterval(() => {
      heroImgs[i].classList.remove('is-current');
      i = (i + 1) % heroImgs.length;
      heroImgs[i].classList.add('is-current');
    }, 7000);
  }
</script>
