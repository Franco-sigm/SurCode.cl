<section id="inicio" class="relative min-h-screen flex items-center justify-center pt-32 pb-20 overflow-hidden bg-[#050810]">
  <div class="absolute inset-0 z-0 pointer-events-none">
    <div 
      class="absolute inset-0 opacity-[0.25]" 
      style="background-image: repeating-radial-gradient(circle at center, transparent 0, transparent 40px, #334155 41px, #334155 42px);"
    ></div>
    
    <div class="absolute inset-0 bg-gradient-to-b from-[#050810] via-transparent to-[#050810]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_0%,#050810_90%)]"></div>

    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[500px] bg-cyan-500/15 rounded-full blur-[140px] opacity-50"></div>
  </div>

  <div class="container mx-auto px-4 relative z-10 text-center">
    <h1 class="text-4xl md:text-7xl lg:text-8xl font-black tracking-tighter text-white mb-8 uppercase leading-[0.9] flex flex-col items-center">
      <div class="overflow-hidden w-full py-2">
        <span id="scroll-left" class="block italic will-change-transform transition-transform duration-75 ease-out">
          Creamos experiencias
        </span>
      </div>
      <div class="overflow-hidden w-full py-2">
        <span id="scroll-right" class="block text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 via-emerald-300 to-cyan-400 bg-[length:200%_auto] animate-gradient font-black will-change-transform transition-transform duration-75 ease-out">
          web de alto nivel
        </span>
      </div>
    </h1>

    <p class="text-slate-400 max-w-2xl mx-auto mb-12 text-base md:text-xl leading-relaxed">
      Diseñamos y desarrollamos sitios web enfocados en <span class="text-white font-bold">rendimiento impecable</span>.
    </p>

    <div class="flex justify-center">
      <a href="#contacto" class="relative group h-14 w-64 overflow-hidden bg-cyan-400 text-[#050810] font-black rounded-full transition-all hover:scale-105 hover:bg-white animate-coin-glow uppercase tracking-widest text-xs flex items-center justify-center border-b-4 border-cyan-600 active:border-b-0 active:translate-y-1">
        
        <div class="absolute inset-0 w-[200%] h-full bg-gradient-to-r from-transparent via-white/80 to-transparent -translate-x-full animate-coin-shine z-20"></div>
        
        <div class="relative z-10">
          <span class="absolute inset-0 flex items-center justify-center whitespace-nowrap animate-fade-1">Solicitar propuesta</span>
          <span class="absolute inset-0 flex items-center justify-center whitespace-nowrap opacity-0 animate-fade-2">¡Haz Click Ahora! 🚀</span>
          <span class="opacity-0 pointer-events-none">Solicitar propuesta</span>
        </div>
      </a>
    </div>
  </div>
</section>

<script>
  const leftLine = document.getElementById('scroll-left');
  const rightLine = document.getElementById('scroll-right');

  window.addEventListener('scroll', () => {
    const value = window.scrollY;
    if (window.innerWidth > 1024) {
      if (leftLine && rightLine) {
        leftLine.style.transform = `translateX(-${value * 0.4}px)`;
        rightLine.style.transform = `translateX(${value * 0.4}px)`;
        const opacity = 1 - (value / 700);
        leftLine.style.opacity = opacity > 0 ? opacity.toString() : "0";
        rightLine.style.opacity = opacity > 0 ? opacity.toString() : "0";
      }
    }
  }, { passive: true });
</script>

<style>
  @keyframes shine-gradient { to { background-position: 200% center; } }
  .animate-gradient { animation: shine-gradient 5s linear infinite; }
  
  /* Brillo Constante de Moneda (Barrido diagonal) */
  @keyframes coin-shine {
    0% { transform: translateX(-150%) skewX(-25deg); }
    20% { transform: translateX(150%) skewX(-25deg); }
    100% { transform: translateX(150%) skewX(-25deg); }
  }
  .animate-coin-shine {
    animation: coin-shine 3s infinite cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Pulsación de Brillo Exterior (Glow) cada 2s */
  @keyframes coin-glow {
    0%, 100% { box-shadow: 0 0 10px rgba(34,211,238,0.2); }
    50% { box-shadow: 0 0 35px rgba(34,211,238,0.7); }
  }
  .animate-coin-glow {
    animation: coin-glow 2s infinite ease-in-out;
  }

  /* Animaciones de Fade Cruzado para el Texto */
  @keyframes fade-out-in {
    0%, 45% { opacity: 1; filter: blur(0px); }
    50%, 95% { opacity: 0; filter: blur(4px); }
    100% { opacity: 1; filter: blur(0px); }
  }
  @keyframes fade-in-out {
    0%, 45% { opacity: 0; filter: blur(4px); }
    50%, 95% { opacity: 1; filter: blur(0px); }
    100% { opacity: 0; filter: blur(4px); }
  }
  .animate-fade-1 { animation: fade-out-in 5s infinite; }
  .animate-fade-2 { animation: fade-in-out 5s infinite; }

  .will-change-transform {
    will-change: transform, opacity;
  }
</style>