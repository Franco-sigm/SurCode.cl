<section id="contacto" class="py-24 bg-[#050810] relative overflow-hidden">
  <div class="absolute inset-0 opacity-[0.05]" id="grid-pattern-contact"></div>
  
  <div class="absolute -bottom-24 -left-24 w-96 h-96 bg-purple-500/10 blur-[120px] rounded-full pointer-events-none"></div>
  <div class="absolute -top-24 -right-24 w-96 h-96 bg-cyan-500/10 blur-[120px] rounded-full pointer-events-none"></div>

  <div class="container mx-auto px-6 relative z-10">
    
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/10 mb-6">
        <div class="w-2 h-2 rounded-full bg-green-400 shadow-[0_0_8px_#4ade80] animate-pulse"></div>
        <span class="text-[10px] font-black uppercase tracking-[0.3em] text-slate-400">Status: Online</span>
      </div>
      <h2 class="text-4xl md:text-6xl font-black text-white mb-6 italic tracking-tighter">
        ¿LISTO PARA <span class="text-cyan-400 font-black">EMPEZAR?</span>
      </h2>
      <p class="text-slate-400 max-w-xl mx-auto text-lg font-medium leading-relaxed">
        Escríbeme y diseñemos la solución tecnológica que tu negocio necesita.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start max-w-6xl mx-auto">
      
      <div class="space-y-6">
        <h3 class="text-2xl font-black text-white mb-8 uppercase italic tracking-tight flex items-center gap-3">
          <span class="w-8 h-px bg-cyan-500"></span>
          Canales directos
        </h3>
        
        <div class="flex items-center gap-5 p-6 bg-white/[0.02] backdrop-blur-md border border-white/10 rounded-2xl group hover:border-cyan-500/50 transition-all duration-500">
          <div class="w-14 h-14 bg-white/5 rounded-xl flex items-center justify-center text-cyan-400 group-hover:bg-cyan-500 group-hover:text-white transition-all shadow-inner">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <p class="text-[10px] text-slate-500 uppercase tracking-[0.2em] font-black mb-1">Email Oficial</p>
            <a href="mailto:contacto@surcode.cl" class="text-xl font-bold text-slate-200 hover:text-cyan-400 transition-colors tracking-tight">contacto@surcode.cl</a>
          </div>
        </div>

        <a href="https://wa.me/56958100428" target="_blank" class="flex items-center gap-5 p-6 bg-white/[0.02] backdrop-blur-md border border-white/10 rounded-2xl group hover:border-purple-500/50 transition-all duration-500">
          <div class="w-14 h-14 bg-white/5 rounded-xl flex items-center justify-center text-purple-400 group-hover:bg-purple-500 group-hover:text-white transition-all shadow-inner">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="currentColor" viewBox="0 0 16 16">
              <path d="M13.601 2.326A7.854 7.854 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.933 7.933 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.898 7.898 0 0 0 13.6 2.326zM7.994 14.521a6.573 6.573 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.557 6.557 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592z"/>
            </svg>
          </div>
          <div>
            <p class="text-[10px] text-slate-500 uppercase tracking-[0.2em] font-black mb-1">Respuesta inmediata</p>
            <p class="text-xl font-bold text-slate-200 group-hover:text-purple-400 transition-colors tracking-tight">WhatsApp Directo</p>
          </div>
        </a>

        <div class="p-6 rounded-2xl bg-cyan-500/5 border border-cyan-500/10">
          <p class="text-sm text-slate-400 italic leading-relaxed">
            "En el **Sur del mundo** no dormimos hasta que el código esté perfecto. Horario de atención: **Lun-Dom, 08:00 a 23:00 hrs.**"
          </p>
        </div>
      </div>

      <div class="relative group">
        <form 
          id="contact-form"
          action= "https://formspree.io/f/mbdagglk"
          method="POST" 
          class="bg-white/[0.03] backdrop-blur-xl p-8 rounded-3xl border border-white/10 shadow-2xl relative overflow-hidden transition-all duration-500"
        > <input type="hidden" name="_subject" value="Nuevo Proyecto - Nodo Austral-Estanforchays" />
          <div class="absolute -top-10 -right-10 opacity-10 group-hover:opacity-20 transition-opacity pointer-events-none">
              <svg width="200" height="200" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1">
                  <path d="M5 6L19 6L12 17L5 6Z" />
              </svg>
          </div>

          <div id="form-content" class="space-y-6 relative z-10 transition-opacity duration-500">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="space-y-2">
                  <label class="text-[10px] font-black text-cyan-400 uppercase tracking-widest ml-2">Nombre</label>
                  <input type="text" name="name" placeholder="Ej. Juan Pérez" class="w-full bg-[#050810]/50 border border-white/10 rounded-xl px-4 py-4 text-white focus:outline-none focus:border-cyan-500/50 transition-all placeholder:text-slate-600" required />
              </div>
              <div class="space-y-2">
                  <label class="text-[10px] font-black text-cyan-400 uppercase tracking-widest ml-2">Email</label>
                  <input type="email" name="email" placeholder="tu@empresa.cl" class="w-full bg-[#050810]/50 border border-white/10 rounded-xl px-4 py-4 text-white focus:outline-none focus:border-cyan-500/50 transition-all placeholder:text-slate-600" required />
              </div>
            </div>

            <div class="space-y-2">
              <label class="text-[10px] font-black text-cyan-400 uppercase tracking-widest ml-2">Servicio</label>
              <select name="service" class="w-full bg-[#050810]/50 border border-white/10 rounded-xl px-4 py-4 text-slate-400 focus:outline-none focus:border-cyan-500/50 transition-all appearance-none cursor-pointer" required>
                  <option value="" disabled selected>Selecciona un servicio</option>
                  <option value="landing">Landing Page</option>
                  <option value="web-app">Aplicación Web</option>
                  <option value="corporate">Sitio Corporativo</option>
              </select>
            </div>

            <div class="space-y-2">
              <label class="text-[10px] font-black text-cyan-400 uppercase tracking-widest ml-2">Mensaje</label>
              <textarea name="message" rows="4" placeholder="Cuéntanos sobre tu proyecto..." class="w-full bg-[#050810]/50 border border-white/10 rounded-xl px-4 py-4 text-white focus:outline-none focus:border-cyan-500/50 transition-all placeholder:text-slate-600 resize-none" required></textarea>
            </div>

            <button type="submit" id="submit-button" class="w-full bg-gradient-to-r from-purple-600 to-fuchsia-500 hover:from-purple-500 hover:to-fuchsia-400 text-white font-black uppercase tracking-[0.2em] py-5 rounded-xl transition-all shadow-lg shadow-purple-600/20 active:scale-95 group flex items-center justify-center gap-3 disabled:opacity-50 disabled:cursor-not-allowed">
              <span id="button-text">Desplegar Proyecto</span>
              <svg id="button-icon" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </button>
          </div>

          <div id="success-message" class="hidden flex-col items-center justify-center text-center py-12 space-y-6 relative z-10 opacity-0 transition-opacity duration-500">
            <div class="w-20 h-20 bg-cyan-500/20 rounded-full flex items-center justify-center border border-cyan-500/50 shadow-[0_0_30px_rgba(6,182,212,0.3)]">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                </svg>
            </div>
            <div class="space-y-2">
                <h3 class="text-3xl font-black text-white italic tracking-tighter uppercase">¡SISTEMA ACTUALIZADO!</h3>
                <p class="text-slate-400 max-w-[280px]">Tu solicitud ha sido recibida en el Nodo Austral. Te contactaremos a la brevedad.</p>
            </div>
            <button type="button" id="reset-form" class="text-xs font-black uppercase tracking-widest text-cyan-400 hover:text-white transition-colors underline decoration-cyan-500/30 underline-offset-8">
                Enviar otro requerimiento
            </button>
          </div>
        </form>
      </div>

    </div>
  </div>
</section>

<style>
  #grid-pattern-contact {
    background-image: 
      linear-gradient(to right, #ffffff10 1px, transparent 1px),
      linear-gradient(to bottom, #ffffff10 1px, transparent 1px);
    background-size: 40px 40px;
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const formContent = document.getElementById('form-content');
  const successMessage = document.getElementById('success-message');
  const submitButton = document.getElementById('submit-button') as HTMLButtonElement;
  const buttonText = document.getElementById('button-text');
  const resetButton = document.getElementById('reset-form');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    // Feedback visual de carga
    if (submitButton) submitButton.disabled = true;
    if (buttonText) buttonText.innerText = "PROCESANDO...";

    const formData = new FormData(form);

    try {
      const response = await fetch(form.action, {
        method: form.method,
        body: formData,
        headers: {
          'Accept': 'application/json'
        }
      });

      if (response.ok) {
        // Transición a éxito
        formContent?.classList.add('opacity-0');
        setTimeout(() => {
          formContent?.classList.add('hidden');
          successMessage?.classList.remove('hidden');
          setTimeout(() => {
            successMessage?.classList.add('opacity-100');
            successMessage?.classList.add('flex'); // Asegura el centrado
          }, 50);
        }, 500);
        
        form.reset();
      } else {
        throw new Error('Error en el servidor');
      }
    } catch (error) {
      alert('Hubo un error al enviar el formulario. Por favor, intenta de nuevo o escríbenos directamente.');
      if (submitButton) submitButton.disabled = false;
      if (buttonText) buttonText.innerText = "DESPLEGAR PROYECTO";
    }
  });

  // Lógica para resetear el formulario si el usuario quiere enviar otro
  resetButton?.addEventListener('click', () => {
    successMessage?.classList.remove('opacity-100');
    setTimeout(() => {
      successMessage?.classList.add('hidden');
      formContent?.classList.remove('hidden');
      setTimeout(() => {
        formContent?.classList.remove('opacity-0');
        if (submitButton) submitButton.disabled = false;
        if (buttonText) buttonText.innerText = "DESPLEGAR PROYECTO";
      }, 50);
    }, 500);
  });
</script>