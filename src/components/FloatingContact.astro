---
// Botón de contacto flotante estilo ServiceNow: pill verde fijo abajo-derecha,
// siempre visible, con icono de chat. CTA principal de conversión del sitio.
---

<a
  href="https://wa.me/56958100428"
  target="_blank"
  rel="noopener"
  aria-label="Contactar por WhatsApp"
  class="group fixed top-1/2 -translate-y-1/2 right-8 z-[140] inline-flex items-center gap-2.5
         pl-4 pr-5 py-3 rounded-full
         bg-gradient-to-b from-lime-400 to-green-500 text-[#04101f]
         font-bold text-sm md:text-base
         shadow-[0_8px_30px_rgba(34,197,94,0.45)]
         ring-1 ring-green-300/40
         transition-all duration-300
         hover:scale-105 hover:shadow-[0_10px_40px_rgba(34,197,94,0.6)]
         active:scale-95"
>
  <!-- Halo de atención sutil -->
  <span class="absolute inset-0 -z-10 rounded-full bg-green-400/60 blur-md opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>

  <!-- Icono globo de chat -->
  <span class="flex items-center justify-center w-7 h-7 rounded-full bg-[#04101f]/10">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8 10h8M8 14h5M21 12a8 8 0 01-11.6 7.14L4 20l1.14-4.4A8 8 0 1121 12z" />
    </svg>
  </span>

  <span>Contacto</span>
</a>
