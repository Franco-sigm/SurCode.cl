---
const year = new Date().getFullYear();
---

<footer class="bg-[#050810] border-t border-white/5 pt-16 pb-8 text-slate-400 text-sm relative overflow-hidden">
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-px bg-gradient-to-r from-transparent via-cyan-500/50 to-transparent"></div>

  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
      
      <div class="space-y-6">
        <a href="#" class="flex items-center gap-3 group">
          <div class="relative w-12 h-12 flex items-center justify-center rounded-xl bg-white/5 border border-white/10 group-hover:border-purple-500/50 transition-all duration-500">
             <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" class="w-8 h-8 transition-all duration-500 group-hover:scale-110">
               <path d="M5 6L19 6L12 17L5 6Z" stroke="#22d3ee" stroke-width="1.2" class="opacity-50" />
               <circle cx="5" cy="6" r="1.2" fill="#22d3ee" />
               <circle cx="19" cy="6" r="1.2" fill="#22d3ee" />
               <path d="M12 15L14.5 18.5L12 22L9.5 18.5L12 15Z" fill="url(#footer-grad)" class="drop-shadow-[0_0_8px_rgba(168,85,247,0.9)]" />
               <defs>
                 <linearGradient id="footer-grad" x1="12" y1="15" x2="12" y2="22" gradientUnits="userSpaceOnUse">
                   <stop stop-color="#a855f7" />
                   <stop offset="1" stop-color="#d946ef" />
                 </linearGradient>
               </defs>
             </svg>
          </div>
          <div class="flex flex-col tracking-tighter leading-none uppercase italic">
             <span class="text-2xl font-black text-white">SUR</span>
             <span class="text-2xl font-black text-cyan-400">CODE</span>
          </div>
        </a>
        <p class="max-w-xs leading-relaxed text-slate-400/80">
          Desarrollo web freelance y soluciones digitales de alto impacto. Transformando ideas en software real desde el **Nodo Austral**.
        </p>
        
        <div class="flex gap-4">
            <a href="#" class="w-10 h-10 flex items-center justify-center rounded-lg bg-white/5 border border-white/10 hover:border-cyan-500/50 hover:text-cyan-400 transition-all duration-300">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" /></svg>
            </a>
        </div>
      </div>

      <div>
        <h4 class="text-white font-black uppercase tracking-widest text-xs mb-6">Navegación</h4>
        <ul class="space-y-4">
            <li><a href="#servicios" class="hover:text-cyan-400 transition-colors flex items-center gap-2 group"><span class="w-1.5 h-px bg-cyan-500 group-hover:w-3 transition-all"></span> Servicios</a></li>
            <li><a href="#proceso" class="hover:text-cyan-400 transition-colors flex items-center gap-2 group"><span class="w-1.5 h-px bg-cyan-500 group-hover:w-3 transition-all"></span> Cómo trabajamos</a></li>
            <li><a href="#faq" class="hover:text-cyan-400 transition-colors flex items-center gap-2 group"><span class="w-1.5 h-px bg-cyan-500 group-hover:w-3 transition-all"></span> Dudas frecuentes</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-white font-black uppercase tracking-widest text-xs mb-6">Contacto</h4>
        <ul class="space-y-4 text-slate-400">
            <li class="flex items-center gap-4">
                <div class="w-8 h-8 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center text-cyan-400">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                </div>
                <span>contacto@surcode.cl</span>
            </li>
            <li class="flex items-center gap-4">
                <div class="w-8 h-8 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center text-purple-400">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                </div>
                <span>Santiago, Chile</span>
            </li>
        </ul>
      </div>

    </div>

    <div class="border-t border-white/5 pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-xs tracking-widest uppercase">
        <p>© {year} <span class="text-white font-bold tracking-tighter italic">SUR<span class="text-cyan-400">CODE</span></span>. Todos los derechos reservados.</p>
       
    </div>
  </div>
</footer>