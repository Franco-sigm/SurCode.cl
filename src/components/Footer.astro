---
import Logo from "./Logo.astro";

const year = new Date().getFullYear();

// Banda de confianza: estándares de calidad, pagos y tecnología (look corporativo monocromático).
// NOTA: son marcas representativas para proyectar respaldo. Reemplaza por los SVG oficiales si los tienes.
const trust = [
  { name: "NIC Chile", sub: "Dominios .CL", icon: "star" },
  { name: "SSL Seguro", sub: "Conexión HTTPS", icon: "lock" },
  { name: "Google PageSpeed", sub: "Sitio optimizado", icon: "gauge" },
  { name: "Webpay Plus", sub: "Pagos seguros", icon: "card" },
  { name: "Mercado Pago", sub: "Pagos online", icon: "wallet" },
  { name: "WhatsApp Business", sub: "Soporte directo", icon: "wa" },
];
---

<footer class="bg-[#050810] border-t border-white/5 pt-20 pb-8 text-slate-400 text-sm relative overflow-hidden">
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-px bg-gradient-to-r from-transparent via-cyan-500/50 to-transparent"></div>

  <div class="absolute inset-0 z-0 pointer-events-none opacity-[0.1]">
    <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="wave-grid" width="100" height="100" patternUnits="userSpaceOnUse">
          <path d="M0 50 Q 25 25 50 50 T 100 50" fill="none" stroke="#22d3ee" stroke-width="0.5" />
          <path d="M50 0 Q 75 25 50 50 T 50 100" fill="none" stroke="#22d3ee" stroke-width="0.5" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#wave-grid)" />
    </svg>
    <div class="absolute inset-0 bg-gradient-to-b from-[#050810] via-transparent to-[#050810]"></div>
  </div>

  <div class="absolute -bottom-24 -left-24 w-96 h-96 bg-purple-600/10 rounded-full blur-[100px]"></div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-16 mb-16">
      
      <div class="space-y-6">
        <Logo href="/#inicio" wordClass="text-3xl" />
        <p class="max-w-xs leading-relaxed text-slate-400/80 italic">
          Expertos en <strong>desarrollo web en Chile</strong>. Creamos landing pages y sistemas a medida bajo los mejores estandares de calidad.
        </p>
        
        <div class="flex gap-4">
            <a href="https://github.com/frankwsl" target="_blank" class="w-10 h-10 flex items-center justify-center rounded-lg bg-white/5 border border-white/10 hover:border-cyan-500/50 hover:text-cyan-400 transition-all duration-300">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" /></svg>
            </a>
        </div>
      </div>

      <div>
        <h4 class="text-white font-black uppercase tracking-[0.2em] text-xs mb-8 shadow-cyan-500/20">Mapa del sitio</h4>
        <ul class="space-y-4">
            <li><a href="/#servicios" class="hover:text-cyan-400 transition-colors flex items-center gap-2 group"><span class="w-1.5 h-px bg-cyan-500 group-hover:w-4 transition-all"></span> Servicios Digitales</a></li>
            <li><a href="/#ley-21719" class="hover:text-cyan-400 transition-colors flex items-center gap-2 group"><span class="w-1.5 h-px bg-cyan-500 group-hover:w-4 transition-all"></span> Ley 21.719</a></li>
            <li><a href="/#faq" class="hover:text-cyan-400 transition-colors flex items-center gap-2 group"><span class="w-1.5 h-px bg-cyan-500 group-hover:w-4 transition-all"></span> Dudas Frecuentes</a></li>
            <li><a href="/contacto" class="hover:text-cyan-400 transition-colors flex items-center gap-2 group"><span class="w-1.5 h-px bg-cyan-500 group-hover:w-4 transition-all"></span> Contacto</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-white font-black uppercase tracking-[0.2em] text-xs mb-8">Contacto Directo</h4>
        <ul class="space-y-4 text-slate-400">
            <li class="flex items-center gap-4 group">
                <div class="w-10 h-10 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center text-cyan-400 group-hover:bg-cyan-500/10 transition-colors">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                </div>
                <a data-mail="contacto" data-dom="surcode.cl" data-fill href="#" class="font-medium hover:text-cyan-400 transition-colors">contacto [arroba] surcode.cl</a>
            </li>
            <li class="flex items-center gap-4 group">
                <div class="w-10 h-10 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center text-purple-400 group-hover:bg-purple-500/10 transition-colors">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                </div>
                <span class="font-medium">Santiago, Chile</span>
            </li>
        </ul>
      </div>

    </div>

    <!-- Banda de confianza: estándares, pagos y tecnología -->
    <div class="border-t border-white/5 pt-12 pb-4">
      <p class="text-center text-[10px] uppercase tracking-[0.3em] text-slate-500 mb-9">
        Calidad, seguridad y respaldo en cada proyecto
      </p>
      <div class="flex flex-wrap items-center justify-center gap-x-10 md:gap-x-14 gap-y-8">
        {trust.map((t) => (
          <div class="group flex items-center gap-3 grayscale opacity-70 hover:opacity-100 hover:grayscale-0 transition-all duration-300">
            <span class="text-slate-300 group-hover:text-cyan-400 transition-colors">
              {t.icon === 'star' && (
                <svg class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.9 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l7.1-1.01L12 2z"/></svg>
              )}
              {t.icon === 'lock' && (
                <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="4" y="10" width="16" height="11" rx="2"/><path d="M8 10V7a4 4 0 018 0v3"/><circle cx="12" cy="15.4" r="1.3" fill="currentColor" stroke="none"/></svg>
              )}
              {t.icon === 'gauge' && (
                <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M4.5 18a9 9 0 1115 0"/><path d="M12 13.5l3.5-3.6" stroke-linecap="round"/><circle cx="12" cy="13.8" r="1.4" fill="currentColor" stroke="none"/></svg>
              )}
              {t.icon === 'card' && (
                <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="2.5" y="5.5" width="19" height="13" rx="2"/><path d="M2.5 10h19"/><path d="M6 14.5h4" stroke-linecap="round"/></svg>
              )}
              {t.icon === 'wallet' && (
                <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 8a2 2 0 012-2h11a2 2 0 012 2"/><rect x="3" y="8" width="18" height="11" rx="2"/><circle cx="16.5" cy="13.5" r="1.3" fill="currentColor" stroke="none"/></svg>
              )}
              {t.icon === 'wa' && (
                <svg class="w-7 h-7" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.872.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.002-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884"/></svg>
              )}
            </span>
            <span class="leading-tight">
              <span class="block font-bold text-sm text-slate-200 tracking-tight whitespace-nowrap">{t.name}</span>
              <span class="block text-[10px] uppercase tracking-widest text-slate-500">{t.sub}</span>
            </span>
          </div>
        ))}
      </div>
    </div>

    <div class="border-t border-white/5 pt-8 flex flex-col md:flex-row justify-between items-center gap-6 text-[10px] tracking-[0.3em] uppercase">
        <p class="text-slate-500">© {year} <span class="font-black tracking-tight lowercase"><span class="text-white">sur</span><span class="text-cyan-400">code</span></span>. Todos los derechos reservados.</p>
        <div class="flex gap-8 text-slate-500">
          <a href="/privacidad" class="hover:text-white transition-colors">Política de Privacidad</a>
          <a href="/terminos" class="hover:text-white transition-colors">Términos de Servicio</a>
        </div>
    </div>
  </div>
</footer>