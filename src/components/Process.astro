---
const steps = [
  {
    step: "01",
    title: "Descubrimiento",
    description: "Analizamos tu visión para definir el stack óptimo. Creamos software de alto rendimiento evitando limitaciones de plataformas prefabricadas para garantizar una escalabilidad absoluta bajo el sello austral.",
    icon: "M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
  },
  {
    step: "02",
    title: "Prototipado",
    description: "Diseñamos la interfaz y la experiencia de usuario (UX/UI). Verás cómo lucirá tu software antes de escribir la primera línea de código mediante prototipos interactivos de alta fidelidad.",
    icon: "M4 5a1 1 0 011-1h14a1 1 0 011 1v14a1 1 0 01-1 1H5a1 1 0 01-1-1V5z M4 9h16 M9 4v16"
  },
  {
    step: "03",
    title: "Desarrollo Ágil",
    description: "Programamos con entregas constantes. Usamos entornos Linux y control de versiones para un desarrollo limpio, seguro y modular, optimizado para el despliegue continuo.",
    icon: "M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
  },
  {
    step: "04",
    title: "Lanzamiento y QA",
    description: "Sometemos el software a pruebas rigurosas y lo desplegamos en la nube. Tu proyecto queda listo para el mundo real con el respaldo técnico y la garantía de SurCode.",
    icon: "M15.5 8.5l-7 7m0-7l7 7m2-13.5l-3 3m-9 9l-3 3m13-13L16 4m-8 8L4 16"
  }
];
---

<section id="proceso" class="py-24 bg-[#050810] relative overflow-hidden">
  <div class="absolute inset-0 opacity-[0.05]" id="grid-pattern"></div>
  
  <div class="container mx-auto px-6 relative z-10">
    
    <div class="mb-20">
      <div class="inline-flex items-center gap-3 px-4 py-2 rounded-xl bg-white/5 border border-white/10 mb-6">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" class="text-purple-500">
           <path d="M5 6L19 6L12 17L5 6Z" stroke="currentColor" stroke-width="2"/>
           <circle cx="12" cy="17" r="2" fill="currentColor" />
        </svg>
        <span class="text-[10px] font-black uppercase tracking-[0.3em] text-cyan-400">Workflow SurCode</span>
      </div>
      
      <h2 class="text-4xl md:text-5xl font-black text-white mb-6 italic tracking-tighter">
        EL CAMINO AL <span class="text-cyan-400">ÉXITO DIGITAL</span>
      </h2>
      <p class="text-slate-400 max-w-2xl text-lg font-medium leading-relaxed">
        Un flujo de trabajo transparente diseñado para eliminar la incertidumbre y garantizar resultados profesionales con el sello del <span class="text-purple-400">Nodo Austral</span>.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 relative">
      
      <div class="hidden lg:block absolute top-12 left-0 w-full h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>

      {steps.map((item) => (
        <div class="relative group">
          <div class="w-16 h-16 rounded-2xl bg-white/5 border border-white/10 flex items-center justify-center mb-8 relative z-10 transition-all duration-500 group-hover:border-cyan-500/50 group-hover:bg-cyan-500/10 group-hover:-translate-y-2">
            <span class="text-xl font-black text-white group-hover:text-cyan-400 transition-colors">
              {item.step}
            </span>
            <div class="absolute inset-0 rounded-2xl bg-cyan-500/20 blur-xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
          </div>

          <div class="space-y-4">
            <div class="flex items-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-purple-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
              </svg>
              <h3 class="text-xl font-black text-white uppercase italic tracking-tight">
                {item.title}
              </h3>
            </div>
            
            <p class="text-slate-400 leading-relaxed text-sm font-medium">
              {item.description}
            </p>
          </div>

          <div class="hidden lg:block absolute top-12 -right-4 text-white/10 group-last:hidden">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor">
              <path d="M9 5l7 7-7 7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-20 p-8 rounded-3xl bg-gradient-to-r from-purple-900/20 to-cyan-900/20 border border-white/5 flex flex-col md:flex-row items-center justify-between gap-6 backdrop-blur-sm">
      <div class="text-center md:text-left">
        <h4 class="text-xl font-bold text-white mb-1 tracking-tight">¿Listo para iniciar la fase de Descubrimiento?</h4>
        <p class="text-slate-400 text-sm">Tu proyecto merece la arquitectura sólida del Nodo Austral.</p>
      </div>
      <a
        href="#" data-wa="NTY5NTgxMDA0Mjg="
        target="_blank"
        class="px-10 py-4 bg-gradient-to-r from-purple-600 to-fuchsia-500 text-white rounded-full font-black uppercase tracking-widest text-xs shadow-lg hover:shadow-[0_0_30px_rgba(168,85,247,0.5)] transition-all hover:scale-105"
      >
        Agendar Consultoría Gratuita
      </a>
    </div>

  </div>
</section>

<style>
  /* PATRÓN DE GRID TÉCNICO */
  #grid-pattern {
    background-image: 
      linear-gradient(to right, #ffffff10 1px, transparent 1px),
      linear-gradient(to bottom, #ffffff10 1px, transparent 1px);
    background-size: 40px 40px;
  }
</style>