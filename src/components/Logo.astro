---
interface Props {
  href?: string;
  /** Tamaño del cuadro del monograma (incluye w/h, rounded y text size de "SC") */
  boxClass?: string;
  /** Tamaño del wordmark "surcode" */
  wordClass?: string;
}

const {
  href = "#inicio",
  boxClass = "w-9 h-9 rounded-lg text-sm",
  wordClass = "text-xl",
} = Astro.props;
---

<a href={href} class="flex items-center gap-2.5 group select-none" aria-label="surcode - inicio">
  <span
    class={`relative flex items-center justify-center font-black tracking-tighter text-[#04101f] bg-gradient-to-br from-cyan-400 to-emerald-400 shadow-lg shadow-cyan-500/20 group-hover:shadow-cyan-500/50 group-hover:scale-105 transition-all duration-300 ${boxClass}`}
  >
    SC
    <!-- brillo sutil en hover -->
    <span class="pointer-events-none absolute inset-0 rounded-[inherit] bg-white/0 group-hover:bg-white/10 transition-colors"></span>
  </span>
  <span class={`font-black tracking-tight lowercase leading-none ${wordClass}`}>
    <span class="text-white">sur</span><span class="text-cyan-400">code</span>
  </span>
</a>
