---
interface Props {
  href?: string;
  /** Tamaño del wordmark "surcode" */
  wordClass?: string;
}

const {
  href = "#inicio",
  wordClass = "text-xl",
} = Astro.props;
---

<a href={href} class="flex items-center group select-none" aria-label="surcode - inicio">
  <span class={`logo-word relative font-black -tracking-[0.04em] lowercase leading-none group-hover:scale-105 transition-transform duration-300 ${wordClass}`}>
    <span class="text-white">s</span><span class="text-[#62d84e]">u</span><span class="text-white">rcode</span>
    <span class="absolute -top-0.5 -right-2.5 text-[0.4em] font-bold text-white/70 align-super">®</span>
  </span>
</a>

<style>
  /* Tipografía redondeada estilo ServiceNow (Gilroy) -> Poppins como alternativa libre */
  .logo-word {
    font-family: 'Poppins', 'Geist', system-ui, sans-serif;
    font-weight: 800;
  }
</style>
