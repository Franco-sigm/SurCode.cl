---
// Definimos los datos de tus servicios en un Array (Lista)
// Esto hace que sea muy fácil editar textos o agregar servicios en el futuro.
const services = [
  {
    title: "Landing Pages",
    description: "Páginas de aterrizaje diseñadas para vender. Rápidas, optimizadas para móviles y enfocadas en convertir visitantes en clientes.",
    icon: "rocket", // Usaremos esto para elegir el ícono
    color: "from-blue-400 to-cyan-300"
  },
  {
    title: "Aplicaciones Web a Medida",
    description: "Sistemas de gestión personalizados (como software para condominios, inventarios o reservas) que optimizan la operación de tu negocio.",
    icon: "code",
    color: "from-emerald-400 to-green-300"
  },
  {
    title: "Sitios Corporativos",
    description: "Tu presencia digital profesional. Sitios web modernos, seguros y autoadministrables para empresas que buscan proyectar confianza.",
    icon: "globe",
    color: "from-purple-400 to-pink-300"
  }
];
---

<section id="servicios" class="py-24 bg-slate-900/50">
  <div class="container mx-auto px-4">
    
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        Servicios <span class="text-blue-500">Integrales</span>
      </h2>
      <p class="text-slate-400 max-w-2xl mx-auto">
         construimos herramientas que ayudan a tu negocio a crecer y funcionar mejor.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {services.map((item) => (
        <div class="group p-8 bg-slate-800 border border-slate-700 rounded-2xl hover:border-slate-500 transition-all duration-300 hover:-translate-y-2 hover:shadow-xl hover:shadow-blue-500/10">
          
          <div class={`w-14 h-14 rounded-lg bg-gradient-to-br ${item.color} flex items-center justify-center mb-6 group-hover:scale-110 transition-transform`}>
            {/* Lógica condicional para mostrar el ícono correcto según el nombre */}
            
            {item.icon === 'rocket' && (
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-slate-900" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            )}

            {item.icon === 'code' && (
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-slate-900" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
              </svg>
            )}

            {item.icon === 'globe' && (
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-slate-900" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
              </svg>
            )}
            
          </div>

          <h3 class="text-xl font-bold text-white mb-3">{item.title}</h3>
          <p class="text-slate-400 leading-relaxed">
            {item.description}
          </p>

        </div>
      ))}
    </div>

  </div>
</section>