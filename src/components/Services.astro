---
const services = [
  {
    title: "Automatizaciones a Medida",
    subtitle: "Recupera tu tiempo, elimina lo repetitivo",
    description: "Diseñamos flujos que ejecutan tus tareas manuales de forma automática, conectando tus herramientas para que tu negocio funcione solo.",
    features: ["Automatización de tareas repetitivas", "Integración entre tus apps y APIs", "Flujos de trabajo personalizados", "Reportes y alertas automáticas", "Soporte y mantención continua"],
    icon: "automation",
    gradient: "from-violet-500 via-fuchsia-400 to-purple-600",
    iconColor: "text-fuchsia-400"
  },
  {
    title: "Integraciones de Inteligencia Artificial",
    subtitle: "Lleva tu negocio a la vanguardia",
    description: "Conectamos modelos de IA a tus procesos: chatbots, agentes y análisis inteligente que trabajan por ti las 24 horas.",
    features: ["Chatbots y asistentes con IA", "Agentes autónomos a medida", "Integración con tus sistemas y datos", "Procesamiento de documentos y texto", "Ajuste y monitoreo continuo"],
    isFeatured: true,
    icon: "ai",
    gradient: "from-cyan-500 via-blue-400 to-indigo-600",
    iconColor: "text-cyan-400"
  },
  {
    title: "Seguridad e Integridad de Datos",
    subtitle: "Protege lo más valioso de tu negocio",
    description: "Auditamos y blindamos tu infraestructura para mantener tus datos seguros, íntegros y siempre disponibles.",
    features: ["Auditoría de seguridad", "Cifrado y respaldos automáticos", "Control de accesos y roles", "Buenas prácticas y cumplimiento", "Monitoreo y respuesta ante incidentes"],
    icon: "shield",
    gradient: "from-amber-500 via-orange-400 to-rose-500",
    iconColor: "text-amber-400"
  },
  {
    title: "Sistemas de Gestión Empresarial",
    subtitle: "Administración y control a medida",
    description: "Desarrollamos software de gestión hecho a tu medida para centralizar, ordenar y optimizar todas tus operaciones.",
    features: ["Gestión de inventario", "Paneles de control y reportes", "Roles y permisos de usuario", "Interfaz simple e intuitiva", "Soporte técnico", "Hosting y dominio .cl/.com GRATIS por 1 año"],
    icon: "dashboard",
    gradient: "from-emerald-500 via-teal-400 to-emerald-600",
    iconColor: "text-emerald-400"
  },
  {
    title: "E-commerce",
    subtitle: "Tu tienda online lista para vender",
    description: "Creamos tiendas online potentes y seguras para que vendas tus productos de forma masiva y sin complicaciones.",
    features: ["Carrito de compras", "Gestión de inventario", "Pagos seguros", "Experiencia de usuario fluida", "Soporte técnico", "Hosting y dominio .cl/.com GRATIS por 1 año"],
    icon: "database",
    gradient: "from-purple-500 via-fuchsia-400 to-purple-600",
    iconColor: "text-purple-400"
  },
];
---

<section id="servicios" class="py-24 bg-[#050810] relative overflow-hidden">
  
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 opacity-[0.15]" 
         style="background-image: repeating-radial-gradient(circle at center, transparent 0, transparent 40px, #1e293b 41px, #1e293b 42px);">
    </div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-blue-500/10 rounded-full blur-[120px] animate-pulse"></div>
  </div>

  <div class="container mx-auto px-6 relative z-10">
    
    <div class="text-center mb-20">
      <h2 class="text-5xl md:text-6xl font-black text-white mb-6 tracking-tighter uppercase">
        Soluciones <span class="bg-clip-text text-transparent bg-gradient-to-r from-cyan-400 to-emerald-400">Digitales</span>
      </h2>
      <p class="text-slate-400 max-w-2xl mx-auto text-lg leading-relaxed font-medium">
        Transformamos tu marca personal en una <span class="text-white">máquina de ventas</span> con tecnología de última generación.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10 max-w-7xl mx-auto items-stretch">
      {services.map((item) => (
        <div class={`group relative p-[1px] rounded-[2.5rem] transition-all duration-500 hover:scale-[1.03] ${item.isFeatured ? 'lg:scale-105 z-20' : 'z-10'}`}>
          
          <div class={`absolute inset-0 rounded-[2.5rem] bg-gradient-to-br ${item.gradient} opacity-30 group-hover:opacity-100 transition-opacity blur-[2px]`}></div>
          
          <div class="relative h-full w-full bg-[#0a0f1d]/90 backdrop-blur-3xl rounded-[2.5rem] p-10 flex flex-col border border-white/5">
            
            {item.isFeatured && (
              <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-cyan-500 text-[#050810] text-[10px] font-black px-4 py-1 rounded-full uppercase tracking-[0.2em] shadow-[0_0_20px_rgba(6,182,212,0.5)]">
                MÁS POPULAR
              </div>
            )}

            <div class="w-20 h-20 rounded-full bg-white/5 border border-white/10 flex items-center justify-center mb-8 mx-auto shadow-inner group-hover:bg-white/10 transition-colors">
              {item.icon === 'ai' && (
                <svg class={`w-10 h-10 ${item.iconColor}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  {/* Chip / procesador que representa la IA */}
                  <rect x="7" y="7" width="10" height="10" rx="2" />
                  <path stroke-linecap="round" d="M10.5 10.5h3v3h-3z" class="opacity-60" />
                  <path stroke-linecap="round" d="M9 3v2M12 3v2M15 3v2M9 19v2M12 19v2M15 19v2M3 9h2M3 12h2M3 15h2M19 9h2M19 12h2M19 15h2" />
                </svg>
              )}
              {item.icon === 'shield' && (
                <svg class={`w-10 h-10 ${item.iconColor}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  {/* Escudo con check: seguridad e integridad */}
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 3l7 3v5c0 4.5-3 8.5-7 10-4-1.5-7-5.5-7-10V6l7-3z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4" />
                </svg>
              )}
              {item.icon === 'automation' && (<svg class={`w-10 h-10 ${item.iconColor}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
                {/* Círculo de órbita que sugiere proceso continuo */}
                <circle cx="12" cy="12" r="8" class="opacity-30" stroke-dasharray="4 4" />
              </svg>
            )}
              {item.icon === 'database' && <svg class="w-10 h-10 text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" /></svg>}
                          {item.icon === 'dashboard' && (
                <svg class={`w-10 h-10 ${item.iconColor}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  {/* Marco del Dashboard */}
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h.188c.621 0 1.125.504 1.125 1.125v6.75c0 .621-.504 1.125-1.125 1.125h-.188A1.125 1.125 0 013 19.875v-6.75zM7.5 9.75C7.5 9.129 8.004 8.625 8.625 8.625h.188c.621 0 1.125.504 1.125 1.125v10.125c0 .621-.504 1.125-1.125 1.125h-.188A1.125 1.125 0 017.5 19.875V9.75zM12 3c.621 0 1.125.504 1.125 1.125v16.875c0 .621-.504 1.125-1.125 1.125h-.188a1.125 1.125 0 01-1.125-1.125V4.125C9.375 3.504 9.879 3 12 3zM16.5 16.125c0-.621.504-1.125 1.125-1.125h.188c.621 0 1.125.504 1.125 1.125v3.75c0 .621-.504 1.125-1.125 1.125h-.188a1.125 1.125 0 01-1.125-1.125v-3.75zM21 12c.621 0 1.125.504 1.125 1.125v6.75c0 .621-.504 1.125-1.125 1.125h-.188a1.125 1.125 0 01-1.125-1.125v-6.75C19.875 12.504 20.379 12 21 12z" />
                  {/* Línea de tendencia/control superior */}
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 10.5l4.5-4.5M10.5 3l4.5 4.5M16.5 13.5L21 9" class="opacity-40" stroke-width="1" />
                </svg>
              )}
            </div>

            <h3 class="text-3xl font-black text-white text-center mb-2 tracking-tight">{item.title}</h3>
            <p class="text-xs text-cyan-400 font-bold uppercase tracking-widest text-center mb-6">{item.subtitle}</p>
            <p class="text-slate-400 text-sm text-center mb-8 leading-relaxed flex-grow">{item.description}</p>

            <ul class="space-y-4 mb-10">
              {item.features.map((feature) => (
                <li class="flex items-center gap-3 text-slate-200 text-xs font-medium">
                  <span class="w-1.5 h-1.5 rounded-full bg-cyan-500 shadow-[0_0_8px_rgba(6,182,212,1)]"></span>
                  {feature}
                </li>
              ))}
            </ul>

            <a href="#contacto" class={`relative overflow-hidden py-4 rounded-full font-black text-xs uppercase tracking-widest transition-all duration-300 text-center ${item.isFeatured ? 'bg-cyan-500 text-[#050810] hover:bg-white shadow-[0_10px_30px_rgba(6,182,212,0.3)]' : 'bg-white/5 text-white border border-white/10 hover:bg-white/10'}`}>
              Cotizar Proyecto
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Animación de rotación lenta para el fondo radial */
  @keyframes rotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  
  /* Puedes añadir un script para revelar las tarjetas al hacer scroll */
</style>