---
// Sección de Servicios: un ∞ (lemniscata) gigante de fondo que LLENA todo el frame,
// con el menú superpuesto encima. Cada servicio es un punto del ∞; al elegir una
// pestaña, el plano (∞ + contenido) se desplaza para centrar ese punto. SVG/CSS.
import fs from 'node:fs';
import path from 'node:path';

// Lista (en build) las imágenes ya optimizadas de public/servicios/<id>/ para alternarlas.
function listImages(dir: string): string[] {
  try {
    return fs.readdirSync(path.join(process.cwd(), 'public', dir))
      .filter((f) => /\.(webp|avif|jpe?g|png)$/i.test(f))
      .sort()
      .map((f) => `/${dir.replace(/^\/+/, '')}/${f}`);
  } catch { return []; }
}

const services = [
  {
    id: "automation", tab: "Automatización",
    subtitle: "Recupera tu tiempo, elimina lo repetitivo",
    title: "Automatizaciones a Medida",
    description: "Diseñamos flujos que ejecutan tus tareas manuales de forma automática, conectando tus herramientas para que tu negocio funcione solo.",
    features: ["Tareas repetitivas automatizadas", "Integración entre apps y APIs", "Flujos de trabajo a medida", "Reportes y alertas automáticas"],
    icon: "⚡",
    imageDir: "servicios/automation",
  },
  {
    id: "ai", tab: "IA",
    subtitle: "Lleva tu negocio a la vanguardia",
    title: "Integraciones de Inteligencia Artificial",
    description: "Conectamos modelos de IA a tus procesos: chatbots, agentes y análisis inteligente que trabajan por ti las 24 horas.",
    features: ["Chatbots y asistentes con IA","Procesamiento de documentos", "Automatización inteligente de tareas", ],
    icon: "🤖",
    imageDir: "servicios/ai",
  },
  {
    id: "shield", tab: "Paginas web ",
    subtitle: "Dale Cara a tu Negocio en Internet",
    title: "Páginas Web Corporativas y portafolios para pofesionales",
    description: "Auditamos y blindamos tu infraestructura para mantener tus datos seguros, íntegros y siempre disponibles.",
    features: ["Pagina web corporativa", "Portafolio para profesionales", "Diseño moderno y responsivo", "Optimización SEO"],
    icon: "🛡️",
    imageDir: "servicios/shield",
  },
  {
    id: "dashboard", tab: "Aplicaciones de Gestion",
    subtitle: "Desarrollo de software a tu medida",
    title: "Sistemas de Gestión Empresarial",
    description: "Desarrollamos software de gestión hecho a tu medida para centralizar, ordenar y optimizar todas tus operaciones.",
    features: ["Gestión de inventario","Administracion de personal", "Paneles de control y reportes", "Roles y permisos de usuario", "Hosting y dominio gratis 1 año"],
    icon: "📊",
    imageDir: "servicios/dashboard",
  },
  {
    id: "ecommerce", tab: "E-commerce",
    subtitle: "Tu tienda lista para vender",
    title: "Tiendas Online (E-commerce)",
    description: "Creamos tiendas online potentes y seguras para que vendas tus productos de forma masiva y sin complicaciones.",
    features: ["Carrito y gestión de inventario", "Pagos seguros", "Experiencia de usuario fluida", "Hosting y dominio gratis 1 año"],
    icon: "🛍️",
    imageDir: "servicios/ecommerce",
  },
];

// Resuelve las imágenes de cada servicio desde su carpeta (vacío => muestra la figura ∞).
const items = services.map((s) => ({
  ...s,
  images: "imageDir" in s && s.imageDir ? listImages(s.imageDir) : [],
}));
---

<section id="servicios" class="relative overflow-hidden min-h-screen"
         style="background: linear-gradient(135deg, #0c3b30 0%, #0a2638 38%, #0a1f31 70%, #0b2740 100%);">

  <!-- Glows de marca -->
  <div class="absolute inset-0 z-0 pointer-events-none">
    <div class="absolute -bottom-40 -left-40 w-[700px] h-[700px] bg-[#2bbf4f]/12 rounded-full blur-[170px]"></div>
    <div class="absolute -top-32 -right-24 w-[600px] h-[600px] bg-[#1f6dd0]/15 rounded-full blur-[160px]"></div>
  </div>

  <!-- Figura ∞ a frame completo (detrás del menú) -->
  <div class="svc-viewport absolute inset-0 z-0 overflow-hidden">
    <div class="svc-plane absolute inset-0">

      <!-- ∞ gigante: tubo 3D + franjas satinadas paralelas + 3 destellos -->
      <svg class="svc-ring absolute left-0 top-0" style="overflow:visible" aria-hidden="true">
        <defs>
          <linearGradient id="svcRingGrad" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0" stop-color="#8ec8ff"/>
            <stop offset="0.45" stop-color="#2f6fed"/>
            <stop offset="0.78" stop-color="#163b9c"/>
            <stop offset="1" stop-color="#0c1f54"/>
          </linearGradient>
        </defs>
        <!-- Cuerpo con degradado vertical -->
        <path class="svc-ring-body" fill="none" stroke="url(#svcRingGrad)" stroke-linejoin="round" stroke-linecap="round"></path>
        <!-- Franjas satinadas (paralelas, desplazadas a lo ancho) -->
        <path class="svc-stripe svc-stripe-d" fill="none" stroke="#0f2f6e" stroke-linecap="round" stroke-linejoin="round" opacity="0.55"></path>
        <path class="svc-stripe svc-stripe-l" fill="none" stroke="#d7ecff" stroke-linecap="round" stroke-linejoin="round" opacity="0.42"></path>
        <path class="svc-stripe svc-stripe-m" fill="none" stroke="#5b8de8" stroke-linecap="round" stroke-linejoin="round" opacity="0.38"></path>
        <!-- Pelos finos que recorren el ∞ de forma aleatoria -->
        {[0,1,2,3,4,5].map(() => (
          <path class="svc-hair" fill="none" stroke="#e6f4ff" stroke-linecap="round" pathLength="100"></path>
        ))}
      </svg>

      <!-- Nodos por servicio -->
      {services.map((_, i) => (
        <span class="svc-node absolute" data-node={i} aria-hidden="true"></span>
      ))}

      <!-- Paneles por servicio -->
      {items.map((s) => (
        <div
          id={`svc-panel-${s.id}`}
          role="tabpanel"
          aria-labelledby={`svc-tab-${s.id}`}
          class="svc-panel absolute flex items-center"
        >
          {s.images.length > 0 && (
            <div class="svc-photo absolute inset-0 overflow-hidden" aria-hidden="true">
              {s.images.map((src, idx) => (
                <img src={src} alt="" data-slide={idx}
                     class:list={["svc-photo-img absolute inset-0 w-full h-full object-cover", { "is-current": idx === 0 }]}
                     loading={idx === 0 ? "eager" : "lazy"} decoding="async" />
              ))}
              <!-- Difuminado: más oscuro del lado izquierdo (donde va el texto blanco) -->
              <div class="absolute inset-0"
                   style="background: linear-gradient(90deg, rgba(8,20,33,0.96) 0%, rgba(8,20,33,0.86) 32%, rgba(8,20,33,0.55) 62%, rgba(8,20,33,0.28) 100%);"></div>
              <!-- Refuerzo vertical para fundir con la sección arriba/abajo -->
              <div class="absolute inset-0"
                   style="background: linear-gradient(180deg, rgba(8,20,33,0.5) 0%, transparent 22%, transparent 68%, rgba(8,20,33,0.7) 100%);"></div>
            </div>
          )}
          <div class="relative z-10 w-full max-w-6xl mx-auto px-6 grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">
            <div>
              <p class="text-xs font-bold uppercase tracking-widest text-[#8fd2ff] mb-3">{s.subtitle}</p>
              <h3 class="font-sn text-2xl md:text-4xl font-extrabold -tracking-[0.02em] text-white leading-tight mb-4">{s.title}</h3>
              <p class="text-slate-300/90 text-sm md:text-base leading-relaxed mb-6 max-w-xl">{s.description}</p>
              <ul class="space-y-2.5 mb-8">
                {s.features.map((f) => (
                  <li class="flex items-center gap-3 text-slate-200 text-sm font-medium">
                    <svg class="w-5 h-5 shrink-0 text-[#3b9eff]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4" />
                      <circle cx="12" cy="12" r="9" class="opacity-30" />
                    </svg>
                    {f}
                  </li>
                ))}
              </ul>
              <a href="/contacto"
                 class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full bg-[#62d84e] text-[#04140c] font-bold text-sm hover:bg-[#74e85f] transition-colors shadow-[0_10px_30px_rgba(98,216,78,0.25)]">
                Cotizar proyecto
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </a>
            </div>
            {s.images.length === 0 && (
              <div class="hidden lg:flex relative rounded-3xl border border-white/10 bg-white/[0.04] backdrop-blur-sm h-[300px] items-center justify-center p-8 shadow-2xl">
                <div class="absolute -bottom-16 -right-10 w-60 h-60 bg-[#3b9eff]/20 blur-[90px] rounded-full"></div>
                <div class="relative w-[230px] bg-white rounded-2xl shadow-2xl p-5">
                  <div class="w-10 h-10 rounded-xl bg-[#3b9eff]/15 flex items-center justify-center text-[#1e5fd0] text-xl mb-3">{s.icon}</div>
                  <p class="text-[#0a0f1d] text-sm font-bold leading-tight mb-3">{s.tab}</p>
                  <div class="space-y-2">
                    {s.features.slice(0, 3).map((f) => (
                      <div class="flex items-center gap-2">
                        <span class="w-4 h-4 rounded-full bg-[#3b9eff]/15 text-[#1e5fd0] text-[10px] flex items-center justify-center shrink-0">✓</span>
                        <span class="text-slate-500 text-[11px] leading-tight">{f}</span>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Menú (overlay por encima de la figura) -->
  <div class="relative z-20 pt-8 px-3 sm:px-4 lg:px-6">
    <div class="svc-tablist relative flex w-full p-2 rounded-full bg-[#091627]/75 border border-white/10 shadow-2xl"
         role="tablist" aria-label="Servicios de SurCode">
      <span class="svc-indicator absolute top-2 bottom-2 left-0 rounded-full bg-white shadow-lg" aria-hidden="true"></span>
      {services.map((s, i) => (
        <button
          role="tab"
          id={`svc-tab-${s.id}`}
          data-tab={s.id}
          aria-controls={`svc-panel-${s.id}`}
          aria-selected={i === 0 ? "true" : "false"}
          tabindex={i === 0 ? "0" : "-1"}
          class="svc-tab relative z-10 flex-1 text-center whitespace-nowrap px-3 py-3.5 rounded-full text-sm md:text-base font-bold transition-colors duration-300"
        >
          {s.tab}
        </button>
      ))}
    </div>
  </div>

</section>

<script>
  const root = document.getElementById('servicios');
  if (root) {
    const tablist = root.querySelector('.svc-tablist') as HTMLElement;
    const tabs = Array.from(root.querySelectorAll<HTMLElement>('[role="tab"]'));
    const indicator = root.querySelector('.svc-indicator') as HTMLElement;
    const viewport = root.querySelector('.svc-viewport') as HTMLElement;
    const plane = root.querySelector('.svc-plane') as HTMLElement;
    const ring = root.querySelector('.svc-ring') as SVGElement;
    const ringBody = root.querySelector('.svc-ring-body') as SVGPathElement;
    const stripeD = root.querySelector('.svc-stripe-d') as SVGPathElement;
    const stripeL = root.querySelector('.svc-stripe-l') as SVGPathElement;
    const stripeM = root.querySelector('.svc-stripe-m') as SVGPathElement;

    // Pelos finos: parámetros aleatorios fijos (offset, dash, velocidad, fase, sentido)
    const hairsEls = Array.from(root.querySelectorAll<SVGPathElement>('.svc-hair'));
    const hairParams = hairsEls.map((h) => {
      const seg = 4 + Math.random() * 8;
      h.style.animationDuration = `${(4 + Math.random() * 7).toFixed(2)}s`;
      h.style.animationDelay = `${(-Math.random() * 12).toFixed(2)}s`;
      if (Math.random() < 0.5) h.style.animationDirection = 'reverse';
      h.style.opacity = (0.35 + Math.random() * 0.5).toFixed(2);
      h.setAttribute('stroke-dasharray', `${seg.toFixed(1)} ${(100 - seg).toFixed(1)}`);
      return { off: (Math.random() * 2 - 1) * 0.42 }; // posición aleatoria a lo ancho
    });
    const nodes = Array.from(root.querySelectorAll<HTMLElement>('.svc-node'));
    const panels = Array.from(root.querySelectorAll<HTMLElement>('.svc-panel'));
    const N = tabs.length;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Slideshow: alterna suavemente (crossfade) las imágenes de fondo de cada servicio
    root.querySelectorAll<HTMLElement>('.svc-photo').forEach((group) => {
      const imgs = Array.from(group.querySelectorAll<HTMLElement>('.svc-photo-img'));
      if (imgs.length < 2 || reduce) return;
      let idx = 0;
      setInterval(() => {
        imgs[idx].classList.remove('is-current');
        idx = (idx + 1) % imgs.length;
        imgs[idx].classList.add('is-current');
      }, 9000);
    });

    let active = 0;
    let vw = 0, vh = 0, Sx = 0, Sy = 0;
    let pts: { x: number; y: number }[] = [];
    const TWO_PI = Math.PI * 2;
    const OFFSET = 0;

    function lem(t: number, cx: number, cy: number) {
      const s = Math.sin(t), c = Math.cos(t), d = 1 + s * s;
      return { x: cx + Sx * (c / d), y: cy + Sy * (s * c / d) };
    }

    function layout() {
      vw = viewport.clientWidth;
      vh = viewport.clientHeight;
      Sx = Math.max(vw * 1.26, 900); // ancho del ∞ (triple de grande)
      Sy = Sx * 1.6;
      const cx = vw / 2, cy = vh / 2;

      pts = [];
      for (let i = 0; i < N; i++) pts.push(lem(OFFSET + (i / N) * TWO_PI, cx, cy));

      // Muestreo de puntos y normales del ∞ (para caminos desplazados a lo ancho)
      const SEG = 300; // alta resolución → curva bien redonda (sin costo de filtros)
      const Ps: { x: number; y: number }[] = [];
      const Ns: { x: number; y: number }[] = [];
      for (let k = 0; k <= SEG; k++) {
        const t = (k / SEG) * TWO_PI;
        const p = lem(t, cx, cy);
        const p2 = lem(t + 1e-3, cx, cy);
        let nx = -(p2.y - p.y), ny = (p2.x - p.x);
        const L = Math.hypot(nx, ny) || 1;
        Ps.push(p); Ns.push({ x: nx / L, y: ny / L });
      }
      // Construye el path del ∞ desplazado `off` px en dirección normal
      const dOff = (off: number) => {
        let s = '';
        for (let k = 0; k < Ps.length; k++) {
          const x = Ps[k].x + Ns[k].x * off, y = Ps[k].y + Ns[k].y * off;
          s += (k === 0 ? 'M' : 'L') + x.toFixed(1) + ' ' + y.toFixed(1) + ' ';
        }
        return s + 'Z';
      };

      ring.style.width = `${vw}px`;
      ring.style.height = `${vh}px`;

      const W = Sx * 0.20;        // ancho del tubo
      const center = dOff(0);
      ringBody.setAttribute('d', center); ringBody.style.strokeWidth = `${W}px`;
      // Franjas satinadas a distintos offsets del ancho
      stripeD.setAttribute('d', dOff(W * 0.22)); stripeD.style.strokeWidth = `${W * 0.16}px`;
      stripeL.setAttribute('d', dOff(-W * 0.20)); stripeL.style.strokeWidth = `${W * 0.14}px`;
      stripeM.setAttribute('d', dOff(W * 0.03)); stripeM.style.strokeWidth = `${W * 0.12}px`;
      // Pelos finos en posiciones aleatorias del ancho (delgados como cabellos)
      const hairW = Math.max(W * 0.01, 1);
      hairsEls.forEach((h, i) => {
        h.setAttribute('d', dOff(W * hairParams[i].off));
        h.style.strokeWidth = `${hairW}px`;
      });

      nodes.forEach((n, i) => { n.style.left = `${pts[i].x}px`; n.style.top = `${pts[i].y}px`; });
      panels.forEach((p, i) => {
        p.style.left = `${pts[i].x - vw / 2}px`;
        p.style.top = `${pts[i].y - vh / 2}px`;
        p.style.width = `${vw}px`;
        p.style.height = `${vh}px`;
      });
    }

    function panTo(i: number, animate: boolean) {
      const tx = vw / 2 - pts[i].x;
      const ty = vh / 2 - pts[i].y;
      if (!animate || reduce) {
        plane.style.transition = 'none';
        plane.style.transform = `translate(${tx}px, ${ty}px)`;
        void plane.offsetWidth;
        plane.style.transition = '';
      } else {
        plane.style.transform = `translate(${tx}px, ${ty}px)`;
      }
    }

    function moveIndicator(i: number) {
      const t = tabs[i];
      if (!indicator || !t) return;
      indicator.style.transform = `translateX(${t.offsetLeft}px)`;
      indicator.style.width = `${t.offsetWidth}px`;
    }

    function highlightNode(i: number) {
      nodes.forEach((n, idx) => n.classList.toggle('is-active', idx === i));
    }

    // Mostrar solo el panel activo / ocultar todos (fade)
    function showActive() {
      panels.forEach((p, idx) => p.classList.toggle('is-shown', idx === active));
    }
    function hideAll() {
      panels.forEach((p) => p.classList.remove('is-shown'));
    }

    function activate(i: number, animate = true) {
      active = i;
      tabs.forEach((t, idx) => {
        const on = idx === i;
        t.setAttribute('aria-selected', String(on));
        t.tabIndex = on ? 0 : -1;
      });
      moveIndicator(i);
      highlightNode(i);
      hideAll();          // los mensajes desaparecen al empezar a navegar
      panTo(i, animate);
      if (!animate || reduce) showActive(); // sin animación: aparece de inmediato
    }

    // Cuando el plano termina de desplazarse, reaparece el panel activo
    plane.addEventListener('transitionend', (e) => {
      if (e.target === plane && e.propertyName === 'transform') showActive();
    });

    tabs.forEach((t, i) => t.addEventListener('click', () => activate(i)));
    tablist?.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key !== 'ArrowRight' && e.key !== 'ArrowLeft') return;
      e.preventDefault();
      const dir = e.key === 'ArrowRight' ? 1 : -1;
      const i = (active + dir + tabs.length) % tabs.length;
      activate(i);
      tabs[i].focus({ preventScroll: true });
    });

    layout();
    activate(0, false);
    requestAnimationFrame(() => { layout(); moveIndicator(0); panTo(0, false); });
    (document as any).fonts?.ready?.then(() => moveIndicator(active));

    let rT: number | null = null;
    window.addEventListener('resize', () => {
      if (rT) cancelAnimationFrame(rT);
      rT = requestAnimationFrame(() => { layout(); moveIndicator(active); panTo(active, false); });
    }, { passive: true });
  }
</script>

<style>
  .font-sn { font-family: 'Poppins', 'Geist', system-ui, sans-serif; }

  .svc-tab { color: #ffffff; }
  .svc-tab[aria-selected="true"] { color: #091627; }
  .svc-indicator {
    transition: transform .45s cubic-bezier(.22,1,.36,1), width .45s cubic-bezier(.22,1,.36,1);
    width: 0;
  }

  .svc-plane {
    transition: transform 1.25s cubic-bezier(.65, 0, .35, 1);
    will-change: transform;
  }

  /* Los mensajes: desaparecen al navegar, reaparecen suave al detenerse */
  .svc-panel {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity .55s ease, transform .55s ease;
  }
  .svc-panel.is-shown {
    opacity: 1;
    transform: translateY(0);
  }

  /* Foto de fondo por servicio: las imágenes se alternan con crossfade + zoom lento (Ken Burns) */
  .svc-photo-img {
    opacity: 0;
    transform: scale(1.06);
    transition: opacity 2.4s ease, transform 12s ease-out;
    will-change: opacity, transform;
  }
  .svc-photo-img.is-current {
    opacity: 1;
    transform: scale(1.12);
  }

  /* ∞: tubo 3D (sin filtros pesados sobre la figura gigante → rendimiento) */
  /* Pelos finos que recorren el ∞ (velocidad/fase/sentido aleatorios vía inline) */
  .svc-hair { animation: svc-ring-flow 6s linear infinite; }
  @keyframes svc-ring-flow { to { stroke-dashoffset: -100; } }

  .svc-node {
    width: 12px; height: 12px; border-radius: 9999px;
    background: #bfe3ff; transform: translate(-50%, -50%);
    box-shadow: 0 0 0 4px rgba(59,158,255,0.18);
    transition: box-shadow .4s ease, background .4s ease;
  }
  .svc-node.is-active {
    background: #ffffff;
    box-shadow: 0 0 18px 4px rgba(59,158,255,0.75), 0 0 0 6px rgba(59,158,255,0.22);
  }

  @media (prefers-reduced-motion: reduce) {
    .svc-indicator, .svc-plane, .svc-panel { transition: none; }
    .svc-hair { animation: none; }
    .svc-photo-img { transition: opacity .4s ease; transform: scale(1); }
  }
</style>
