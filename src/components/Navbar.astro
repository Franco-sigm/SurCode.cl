---
const links = [
  { name: "Servicios", href: "#servicios" },
  { name: "Como trabajamos", href: "#proceso" },
  { name: "Preguntas frecuentes", href: "#faq" } 
];
---

<header class="fixed top-0 w-full z-[150] transition-all duration-500" id="main-header">
  <div class="absolute inset-0 bg-[#050810]/80 backdrop-blur-md border-b border-white/5 opacity-0 transition-opacity duration-500" id="header-bg"></div>
  
  <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between relative z-10 transition-all duration-500" id="header-container">
    
    <a href="#inicio" class="flex items-center gap-2 group">
      <div class="relative w-9 h-9 flex items-center justify-center rounded-lg bg-white/5 border border-white/10 group-hover:border-cyan-500/50 transition-all duration-500 shadow-2xl">
         <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" class="w-6 h-6 transition-all duration-500 group-hover:scale-110">
           <path d="M5 6L19 6L12 17L5 6Z" stroke="#22d3ee" stroke-width="1.5" stroke-linejoin="round" />
           <circle cx="5" cy="6" r="1.5" fill="#22d3ee" />
           <circle cx="19" cy="6" r="1.5" fill="#22d3ee" />
           
           <path d="M12 13.5L15.5 17L12 20.5L8.5 17L12 13.5Z" fill="#a855f7" class="animate-pulse shadow-purple-500" />
           <circle cx="12" cy="17" r="1.2" fill="#d946ef" />
         </svg>
      </div>
      <div class="flex flex-col tracking-tighter leading-none uppercase italic">
         <span class="text-lg font-black text-white">SUR</span>
         <span class="text-lg font-black text-cyan-400">CODE</span>
      </div>
    </a>

    <nav class="hidden md:flex items-center gap-8">
      {links.map((link) => (
        <a href={link.href} class="text-[18px] font-bold uppercase tracking-[0.2em] text-slate-400 hover:text-cyan-400 transition-all relative group">
          {link.name}
          <span class="absolute -bottom-1 left-0 w-0 h-[1px] bg-cyan-500 transition-all duration-300 group-hover:w-full shadow-[0_0_8px_#06b6d4]"></span>
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-4">
      <a href="https://wa.me/56958100428" 
        class="relative overflow-hidden hidden sm:inline-flex items-center gap-3 px-10 py-4 text-[13px] font-black uppercase tracking-[0.2em] text-[#050810] bg-cyan-400 rounded-full transition-all hover:bg-white hover:scale-105 active:scale-95 shadow-[0_0_25px_rgba(34,211,238,0.4)] group">
        
        <span class="absolute inset-0 w-full h-full bg-gradient-to-r from-transparent via-white/70 to-transparent -translate-x-full animate-shine"></span>
        
        <span class="relative flex items-center gap-2">
          <span class="text-base">📞</span>
          Contactar ahora
        </span>
      </a>

      <button id="menu-btn" class="md:hidden p-2 rounded-lg text-cyan-400 transition-colors" aria-label="Abrir menú">
        <svg id="menu-icon" xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path id="menu-path" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-dropdown" class="absolute top-full left-0 w-full bg-[#050810]/95 backdrop-blur-xl border-b border-white/10 overflow-hidden max-h-0 transition-all duration-500 ease-in-out md:hidden shadow-2xl">
    <div class="px-6 py-10 flex flex-col items-center gap-8">
      {links.map((link) => (
        <a href={link.href} class="mobile-link text-2xl font-black text-white uppercase italic tracking-tighter hover:text-cyan-400 transition-colors">
          {link.name}
        </a>
      ))}
      <a href="https://wa.me/56958100428" class="w-full max-w-xs py-4 bg-cyan-400 text-[#050810] flex items-center justify-center gap-2 rounded-xl font-black uppercase tracking-widest text-[10px] shadow-lg shadow-cyan-500/10">
         <span>📞</span>
         Cotizar Ahora
      </a>
    </div>
  </div>
</header>


<script>
  const bg = document.getElementById('header-bg');
  const menuBtn = document.getElementById('menu-btn');
  const dropdown = document.getElementById('mobile-dropdown');
  const menuPath = document.getElementById('menu-path');
  const container = document.getElementById('header-container');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      bg?.classList.add('opacity-100');
      bg?.classList.remove('opacity-0');
      container?.classList.replace('h-20', 'h-16');
    } else {
      bg?.classList.add('opacity-0');
      bg?.classList.remove('opacity-100');
      container?.classList.replace('h-16', 'h-20');
    }
  });

  const toggleMenu = () => {
    const isOpened = dropdown?.style.maxHeight !== '0px' && dropdown?.style.maxHeight !== '';
    if (isOpened) {
      if (dropdown) dropdown.style.maxHeight = '0px';
      menuPath?.setAttribute('d', 'M4 6h16M4 12h16m-7 6h7');
    } else {
      if (dropdown) dropdown.style.maxHeight = dropdown.scrollHeight + 'px';
      menuPath?.setAttribute('d', 'M6 18L18 6M6 6l12 12');
    }
  };

  menuBtn?.addEventListener('click', toggleMenu);

  document.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => {
      if (dropdown) dropdown.style.maxHeight = '0px';
      menuPath?.setAttribute('d', 'M4 6h16M4 12h16m-7 6h7');
    });
  });
</script>