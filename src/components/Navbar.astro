---
// Definimos los enlaces aquí
const links = [
  { name: "Inicio", href: "#inicio" }, 
  { name: "Servicios", href: "#servicios" },
  { name: "Preguntas", href: "#faq" } 
];
---

<header class="fixed top-0 w-full z-50 bg-slate-900/80 backdrop-blur-md border-b border-slate-800">
  <div class="container mx-auto px-4 h-20 flex items-center justify-between">
    
    <a href="#" class="group relative text-3xl font-bold uppercase tracking-tighter block overflow-hidden">
      <span class="relative z-10 text-white group-hover:text-white/80 transition-colors duration-300">
        SUR<span class="text-blue-500">CODE</span>
      </span>
      
      <div class="absolute top-0 left-0 w-full h-full bg-gradient-to-r from-transparent via-white/50 to-transparent -translate-x-[100%] group-hover:animate-shine z-20 pointer-events-none skew-x-12"></div>
      
      <div class="absolute inset-0 bg-blue-500/20 blur-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-full"></div>
    </a>

    <nav class="hidden md:flex items-center gap-8">
      {links.map((link) => (
        <a 
          href={link.href} 
          class="text-lg font-medium text-slate-300 hover:text-white transition-colors"
        >
          {link.name}
        </a>
      ))}
      
      <a 
        href="#contacto" 
        class="bg-blue-600 hover:bg-blue-500 text-white text-lg font-semibold py-2.5 px-6 rounded-full transition-all shadow-lg shadow-blue-500/20"
      >
        Hablemos
      </a>
    </nav>

    <button id="menu-btn" class="md:hidden text-slate-300 hover:text-white focus:outline-none p-2">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16m-7 6h7" />
      </svg>
    </button>

  </div>

  <div id="mobile-menu" class="hidden md:hidden absolute top-20 left-0 w-full bg-slate-900 border-b border-slate-800 shadow-xl">
    <div class="flex flex-col p-4 space-y-4">
      {links.map((link) => (
        <a 
          href={link.href} 
          class="text-lg font-medium text-slate-300 hover:text-white hover:bg-slate-800 px-4 py-2 rounded-lg transition-colors"
        >
          {link.name}
        </a>
      ))}
      <a 
        href="#contacto" 
        class="bg-blue-600 text-white text-center font-semibold py-3 rounded-lg hover:bg-blue-500 transition-colors"
      >
        Hablemos
      </a>
    </div>
  </div>

</header>

<style>
  /* Animación del brillo pasando */
  @keyframes shine {
    from {
      transform: translateX(-150%) skewX(12deg);
    }
    to {
      transform: translateX(150%) skewX(12deg);
    }
  }

  .animate-shine {
    animation: shine 0.7s cubic-bezier(0.4, 0, 0.2, 1);
  }
</style>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');

  if (btn && menu) {
    btn.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });

    // Cerrar el menú al hacer clic en un enlace
    menu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        menu.classList.add('hidden');
      });
    });
  }
</script>