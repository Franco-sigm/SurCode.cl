---
import Logo from "./Logo.astro";

// Enlaces absolutos a secciones de la home: funcionan también desde /contacto u otras páginas
const links = [
  { name: "Servicios", href: "/#servicios" },
  { name: "Ley 21.719", href: "/#ley-21719" },
  { name: "saber mas", href: "/#faq" }
];
---

<header class="fixed top-0 w-full z-[150] transition-all duration-500" id="main-header">
  <div class="absolute inset-0 bg-[#050810]/80 backdrop-blur-md border-b border-white/5 opacity-0 transition-opacity duration-500" id="header-bg"></div>
  
  <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between relative z-10 transition-all duration-500" id="header-container">
    
    <Logo href="/#inicio" wordClass="text-2xl" />

    <nav class="hidden md:flex items-center gap-8">
      {links.map((link) => (
        <a href={link.href} class="font-nav text-[17px] font-bold tracking-[0.01em] text-slate-200 hover:text-cyan-400 transition-colors relative group">
          {link.name}
          <span class="absolute -bottom-1 left-0 w-0 h-[1px] bg-cyan-500 transition-all duration-300 group-hover:w-full shadow-[0_0_8px_#06b6d4]"></span>
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-4">
      <button id="menu-btn" class="md:hidden p-2 rounded-lg text-cyan-400 transition-colors" aria-label="Abrir menú">
        <svg id="menu-icon" xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path id="menu-path" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-dropdown" class="absolute top-full left-0 w-full bg-[#050810]/95 backdrop-blur-xl border-b border-white/10 overflow-hidden max-h-0 transition-all duration-500 ease-in-out md:hidden shadow-2xl">
    <div class="px-6 py-10 flex flex-col items-center gap-8">
      {links.map((link) => (
        <a href={link.href} class="mobile-link font-nav text-2xl font-bold text-white hover:text-cyan-400 transition-colors">
          {link.name}
        </a>
      ))}
      <a href="#" data-wa="NTY5NTgxMDA0Mjg=" class="w-full max-w-xs py-4 bg-cyan-400 text-[#050810] flex items-center justify-center gap-2 rounded-xl font-black uppercase tracking-widest text-[10px] shadow-lg shadow-cyan-500/10">
         <span>📞</span>
         Cotizar Ahora
      </a>
    </div>
  </div>
</header>


<style>
  /* Tipografía del navbar estilo ServiceNow (Lato) */
  .font-nav { font-family: 'Lato', system-ui, -apple-system, sans-serif; }
</style>

<script>
  const bg = document.getElementById('header-bg');
  const menuBtn = document.getElementById('menu-btn');
  const dropdown = document.getElementById('mobile-dropdown');
  const menuPath = document.getElementById('menu-path');
  const container = document.getElementById('header-container');
  const header = document.getElementById('main-header');

  let lastY = window.scrollY;
  let idleTimer: number | undefined;
  const TOP_THRESHOLD = 10;   // arriba del todo: siempre visible
  const IDLE_MS = 1200;       // tras subir y quedar estático: ocultar

  const menuOpen = () =>
    !!dropdown && dropdown.style.maxHeight !== '0px' && dropdown.style.maxHeight !== '';
  const showNav = () => header?.classList.remove('-translate-y-full');
  const hideNav = () => { if (!menuOpen()) header?.classList.add('-translate-y-full'); };

  window.addEventListener('scroll', () => {
    const y = window.scrollY;

    // Fondo + alto del header (comportamiento existente)
    if (y > 50) {
      bg?.classList.add('opacity-100');
      bg?.classList.remove('opacity-0');
      container?.classList.replace('h-20', 'h-16');
    } else {
      bg?.classList.add('opacity-0');
      bg?.classList.remove('opacity-100');
      container?.classList.replace('h-16', 'h-20');
    }

    // Mostrar solo al hacer scroll hacia ARRIBA; ocultar al bajar o quedar estático
    clearTimeout(idleTimer);
    if (y <= TOP_THRESHOLD) {
      showNav();
    } else if (y < lastY) {
      showNav();
      idleTimer = window.setTimeout(hideNav, IDLE_MS);
    } else if (y > lastY) {
      hideNav();
    }
    lastY = y;
  }, { passive: true });

  const toggleMenu = () => {
    const isOpened = dropdown?.style.maxHeight !== '0px' && dropdown?.style.maxHeight !== '';
    if (isOpened) {
      if (dropdown) dropdown.style.maxHeight = '0px';
      menuPath?.setAttribute('d', 'M4 6h16M4 12h16m-7 6h7');
    } else {
      if (dropdown) dropdown.style.maxHeight = dropdown.scrollHeight + 'px';
      menuPath?.setAttribute('d', 'M6 18L18 6M6 6l12 12');
    }
  };

  menuBtn?.addEventListener('click', toggleMenu);

  document.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => {
      if (dropdown) dropdown.style.maxHeight = '0px';
      menuPath?.setAttribute('d', 'M4 6h16M4 12h16m-7 6h7');
    });
  });
</script>