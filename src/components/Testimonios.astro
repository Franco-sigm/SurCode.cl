---
// Testimonios: voces reales de clientes (tono cercano, coloquial chileno).
// Carrusel infinito con pausa al hover. Estilo alineado al resto del sitio
// (Poppins, acento verde #62d84e, tarjetas redondeadas sobre fondo navy).
const testimonials = [
  {
    name: "Camila Fuentes",
    role: "Dueña",
    company: "Tienda Aurora",
    content: "Andábamos con todo en planillas y era un caos. Nos armaron un sistema a nuestra medida y ahora veo el stock y las ventas al tiro desde el celular. Nos sacaron de un tremendo problema.",
    color: "from-[#2bbf4f] to-[#1f8f3a]",
  },
  {
    name: "Rodrigo Tapia",
    role: "Gerente",
    company: "Viña Las Garzas",
    content: "Tenía mis dudas con esto de la IA, pensé que era puro humo. Pero el asistente que nos hicieron responde a los clientes de noche y nos llegan las consultas ya filtradas. Una mano santa.",
    color: "from-[#3b9eff] to-[#1f6dd0]",
  },
  {
    name: "Daniela Rojas",
    role: "Corredora",
    company: "Propiedades del Valle",
    content: "Lo que más valoro es que cachan el rubro. No tuve que explicarles todo de cero; entendieron al toque cómo funciona una corredora y me dejaron las propiedades ordenadas.",
    color: "from-[#a855f7] to-[#7c3aed]",
  },
  {
    name: "Matías Herrera",
    role: "Administrador",
    company: "Turismo Caleta Sur",
    content: "La web nueva nos dejó la firma. Quedó rápida, se ve pro y por fin aparecemos en Google. Nos han llegado reservas de gente que antes ni sabía que existíamos.",
    color: "from-[#06b6d4] to-[#0891b2]",
  },
  {
    name: "Paula Cárdenas",
    role: "Socia",
    company: "Clínica Sonríe",
    content: "Automatizaron la agenda, la facturación y los recordatorios. Me ahorré como dos días de pega a la semana, en serio. Y bajaron un montón las inasistencias.",
    color: "from-[#f59e0b] to-[#d97706]",
  },
  {
    name: "Felipe Moya",
    role: "Jefe de Operaciones",
    company: "Transportes Andes",
    content: "Partimos con una idea media vaga y ellos la ordenaron. Cero tecnicismos, te explican en simple y cumplen los plazos. Ahora seguimos cada despacho en tiempo real.",
    color: "from-[#ef4444] to-[#dc2626]",
  },
];

// Duplicamos el array para el efecto de scroll infinito suave
const doubleTestimonials = [...testimonials, ...testimonials];
---

<section class="py-24 overflow-hidden relative"
         style="background: linear-gradient(180deg, #050810 0%, #0a1322 50%, #050810 100%);">
  <!-- Glow de marca -->
  <div class="absolute inset-0 z-0 pointer-events-none">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[700px] h-[400px] bg-[#2bbf4f]/8 rounded-full blur-[170px]"></div>
  </div>

  <div class="container mx-auto px-6 mb-14 text-center relative z-10">
    <span class="inline-block text-[11px] font-bold uppercase tracking-[0.3em] text-[#62d84e] mb-4">Testimonios</span>
    <h2 class="font-sn text-3xl md:text-4xl lg:text-5xl font-extrabold -tracking-[0.02em] text-white leading-[1.05]">
      Lo que dicen de trabajar con nosotros
    </h2>
    <p class="text-slate-300/80 text-base md:text-lg mt-5 max-w-xl mx-auto">
      Historias reales de clientes que dieron el paso. En sus palabras.
    </p>
  </div>

  <div class="relative flex overflow-hidden z-10">
    <div class="flex animate-scroll hover:[animation-play-state:paused] whitespace-nowrap gap-6 py-4">
      {doubleTestimonials.map((t) => (
        <div class="w-[350px] shrink-0 rounded-3xl border border-white/10 bg-white/[0.03] p-7 transition-all duration-300 hover:bg-white/[0.06] hover:border-[#62d84e]/40 hover:-translate-y-1">
          <!-- Comilla decorativa -->
          <svg class="w-9 h-9 text-[#62d84e]/25 mb-3" fill="currentColor" viewBox="0 0 24 24">
            <path d="M9.5 8C7 8 5 10 5 12.5V18h6v-6H8c0-1.7 1.3-3 3-3V8H9.5zm9 0C16 8 14 10 14 12.5V18h6v-6h-3c0-1.7 1.3-3 3-3V8h-1.5z"/>
          </svg>

          <p class="text-slate-200/90 text-[15px] leading-relaxed whitespace-normal mb-6">
            {t.content}
          </p>

          <div class="flex items-center gap-3 pt-5 border-t border-white/5">
            <div class={`w-11 h-11 rounded-full bg-gradient-to-br ${t.color} flex items-center justify-center text-white font-bold shadow-lg shrink-0`}>
              {t.name.charAt(0)}
            </div>
            <div class="flex flex-col min-w-0">
              <span class="text-white font-bold text-sm tracking-tight truncate">{t.name}</span>
              <span class="text-slate-400 text-xs truncate">{t.role} · {t.company}</span>
            </div>
            <div class="flex gap-0.5 ml-auto shrink-0">
              {[1, 2, 3, 4, 5].map(() => (
                <svg class="w-3.5 h-3.5 text-amber-400 fill-current" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="absolute inset-y-0 left-0 w-32 bg-gradient-to-r from-[#050810] to-transparent z-10 pointer-events-none"></div>
    <div class="absolute inset-y-0 right-0 w-32 bg-gradient-to-l from-[#050810] to-transparent z-10 pointer-events-none"></div>
  </div>
</section>

<style>
  .font-sn { font-family: 'Poppins', 'Geist', system-ui, sans-serif; }

  @keyframes scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(calc(-350px * 6 - 1.5rem * 6)); }
  }

  .animate-scroll {
    animation: scroll 45s linear infinite;
  }

  /* Pausar al pasar el mouse para que el usuario pueda leer mejor */
  .animate-scroll:hover {
    animation-play-state: paused;
  }

  @media (prefers-reduced-motion: reduce) {
    .animate-scroll { animation: none; }
  }
</style>
