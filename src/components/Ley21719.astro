---
// Sección de servicio: Cumplimiento de la Ley 21.719 (Protección de Datos Personales, Chile).
// Diseñada para reflejar los módulos de la futura plataforma de cumplimiento de SurCode.
// CTA principal: diagnóstico gratis por WhatsApp. CTA secundario: preparado para enlazar a la plataforma.

// TODO: reemplazar por la URL de la plataforma cuando esté disponible (ej. https://cumplimiento.surcode.cl)
const PLATAFORMA_URL = "#contacto";
---

<section id="ley-21719" class="relative py-24 overflow-hidden">
  <!-- Fondo estilo Hero: navy oscuro (arriba-izq) -> azul brillante (abajo-der) -->
  <div class="absolute inset-0 z-0 pointer-events-none">
    <div class="absolute inset-0 bg-gradient-to-br from-[#04101f] via-[#06203f] to-[#0a4d8f]"></div>

    <!-- Patrón radial sutil (igual que el Hero) -->
    <div
      class="absolute inset-0 opacity-[0.12]"
      style="background-image: repeating-radial-gradient(circle at center, transparent 0, transparent 40px, #334155 41px, #334155 42px);"
    ></div>

    <!-- Glows de acento -->
    <div class="absolute top-1/3 right-0 w-[700px] h-[500px] bg-cyan-500/20 rounded-full blur-[160px] animate-float-slow"></div>
    <div class="absolute bottom-0 left-0 w-[600px] h-[400px] bg-emerald-500/10 rounded-full blur-[160px] animate-float-slower"></div>
  </div>

  <div class="container mx-auto px-6 relative z-10">

    <!-- Hero de dos columnas -->
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Columna izquierda: texto -->
      <div>
        <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-amber-400/40 bg-amber-400/10 text-amber-300 text-xs font-bold uppercase tracking-widest mb-6">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full rounded-full bg-amber-400 opacity-75 animate-ping"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-amber-400"></span>
          </span>
          Nueva Ley · Vigencia 1 dic 2026
        </span>

        <h2 class="font-sn text-3xl md:text-4xl lg:text-5xl font-extrabold -tracking-[0.02em] leading-[1.05] mb-6">
          
          <span class="block text-white"> Cumplir la Ley 21.719 sin frenar tu negocio.</span>
        </h2>

        <p class="text-slate-300/90 text-base md:text-lg leading-relaxed max-w-xl mb-10">
          La nueva Ley de Protección de Datos obliga a toda empresa que maneje datos de clientes —ventas, salud,
          finanzas, RRHH— sin importar su tamaño. En SurCode construimos el software que te deja en regla
          <span class="text-white font-semibold">antes de la fiscalización</span>.
        </p>

        <div class="flex justify-center">
          <a href={PLATAFORMA_URL}
             class="group inline-flex items-center gap-2 text-white font-bold text-sm hover:text-[#62d84e] transition-colors">
            Conoce nuestra plataforma
            <svg class="w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Columna derecha: panel visual -->
      <div class="relative rounded-3xl overflow-hidden border border-white/10 shadow-2xl min-h-[480px]">
        <!-- Fondo degradado del panel -->
        <div class="absolute inset-0 bg-gradient-to-br from-[#0c2a22] via-[#0a2640] to-[#142a63]"></div>
        <div class="absolute inset-0 opacity-[0.12]"
             style="background-image: repeating-radial-gradient(circle at center, transparent 0, transparent 38px, #334155 39px, #334155 40px);"></div>
        <!-- Glow verde decorativo -->
        <div class="absolute -bottom-16 -right-10 w-72 h-72 bg-[#62d84e]/25 blur-[110px] rounded-full"></div>

        <!-- Ejecutiva (avatar circular) en la esquina inferior derecha -->
        <img src="/ejecutiva-circulo.webp" alt="Ejecutiva supervisando el cumplimiento de datos"
             class="absolute bottom-5 right-5 w-32 sm:w-40 md:w-44 aspect-square rounded-full object-cover ring-2 ring-white/20 shadow-2xl z-20 select-none pointer-events-none"
             loading="lazy" decoding="async" width="900" height="900" />

        <!-- Estrella verde brillante: hace "pop" desde el centro al cargar -->
        <div class="ley-star absolute bottom-6 left-6 w-24 sm:w-28 md:w-32 z-20 pointer-events-none select-none" aria-hidden="true">
          <svg viewBox="-8 -8 116 116" class="w-full h-full overflow-visible">
            <defs>
              <linearGradient id="leyStarFill" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0" stop-color="#84ef67"/>
                <stop offset="0.5" stop-color="#62d84e"/>
                <stop offset="1" stop-color="#3aab2b"/>
              </linearGradient>
            </defs>
            <path d="M50,7 L61.76,35.82 L92.8,38.1 L69.02,58.18 L76.45,88.4 L50,72 L23.55,88.4 L30.98,58.18 L7.2,38.1 L38.24,35.82 Z"
                  fill="url(#leyStarFill)" stroke="#2f7d1f" stroke-width="5.5" stroke-linejoin="round"/>
          </svg>
        </div>

        <!-- Contenido superpuesto -->
        <div class="relative z-20 p-8 md:p-10">
          <p class="font-sn text-3xl md:text-4xl font-extrabold -tracking-[0.02em] leading-tight mb-6">
            <span class="text-[#62d84e]">Protege los datos.</span><br>
            <span class="text-white">Evita las multas.</span>
          </p>

          <!-- Contador integrado -->
          <p class="text-xs uppercase tracking-widest text-[#62d84e] font-bold mb-2">Plazo para estar en regla</p>
          <div id="ley-countdown" class="flex items-end gap-2.5 text-white mb-1" data-deadline="2026-12-01T00:00:00-03:00" data-start="2024-12-13T00:00:00-03:00">
            <div><span data-unit="dias" class="block text-3xl md:text-4xl font-black tabular-nums leading-none">—</span><span class="text-[10px] uppercase tracking-widest text-slate-400">días</span></div>
            <span class="text-xl font-black text-slate-500 pb-2.5">:</span>
            <div><span data-unit="horas" class="block text-3xl md:text-4xl font-black tabular-nums leading-none">—</span><span class="text-[10px] uppercase tracking-widest text-slate-400">hrs</span></div>
            <span class="text-xl font-black text-slate-500 pb-2.5">:</span>
            <div><span data-unit="min" class="block text-3xl md:text-4xl font-black tabular-nums leading-none">—</span><span class="text-[10px] uppercase tracking-widest text-slate-400">min</span></div>
          </div>
          <p class="text-slate-400 text-xs">hasta el 1 de diciembre de 2026</p>
        </div>

        <!-- Barra de progreso verde (se llena según el tiempo transcurrido) -->
        <div class="absolute bottom-0 inset-x-0 h-1.5 bg-white/10 z-30">
          <div id="ley-progress" class="h-full bg-[#62d84e] transition-[width] duration-1000" style="width:0%"></div>
        </div>
      </div>

    </div>

    <!-- Saber más: explicación para quien no conoce la ley -->
    <div class="text-center mt-16">
      <button id="ley-saber-btn" type="button" aria-expanded="false" aria-controls="ley-explainer"
              class="group inline-flex items-center gap-2 text-slate-300 hover:text-[#62d84e] text-sm font-semibold transition-colors">
        ¿Qué es la Ley 21.719?
        <svg id="ley-chevron" class="w-4 h-4 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
        </svg>
      </button>
    </div>

    <div id="ley-explainer" class="ley-panel grid grid-rows-[0fr] transition-all duration-500 ease-in-out max-w-4xl mx-auto mt-6">
      <div class="overflow-hidden">
        <div class="rounded-3xl border border-white/5 bg-[#0a0f1d]/80 p-8 md:p-10 text-left grid md:grid-cols-2 gap-8">
          <div>
            <h4 class="text-[#62d84e] font-bold mb-2">¿Qué es?</h4>
            <p class="text-slate-300/90 text-sm leading-relaxed">
              Es la nueva Ley de Protección de Datos Personales de Chile (dic 2024). Reemplaza una ley de 1999 sin
              capacidad real de sanción y, por primera vez, crea una Agencia (APDP) que puede fiscalizar y multar.
              Está inspirada en el GDPR europeo.
            </p>
          </div>
          <div>
            <h4 class="text-[#62d84e] font-bold mb-2">¿A quién aplica?</h4>
            <p class="text-slate-300/90 text-sm leading-relaxed">
              A cualquier empresa —grande o PYME— que recopile o use datos personales: nombres, RUT, correos, datos de
              salud, financieros o de RRHH. Si tienes una base de clientes, te aplica.
            </p>
          </div>
          <div>
            <h4 class="text-[#62d84e] font-bold mb-2">¿Qué te exige?</h4>
            <ul class="text-slate-300/90 text-sm leading-relaxed space-y-1.5 list-disc list-inside marker:text-[#62d84e]">
              <li>Pedir consentimiento explícito para usar los datos.</li>
              <li>Dejar que las personas accedan, corrijan o eliminen sus datos.</li>
              <li>Registrar cómo tratas los datos y avisar filtraciones en 72 horas.</li>
              <li>Aplicar medidas de seguridad reales.</li>
            </ul>
          </div>
          <div>
            <h4 class="text-[#62d84e] font-bold mb-2">¿Qué pasa si no cumplo?</h4>
            <p class="text-slate-300/90 text-sm leading-relaxed">
              Multas de hasta 20.000 UTM (~$1.400 millones) o hasta el 4% de tus ventas anuales en reincidencia.
              La fecha límite para estar en regla es el <span class="text-white font-semibold">1 de diciembre de 2026</span>.
            </p>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<script>
  // Contador regresivo hasta la entrada en vigencia (1 dic 2026)
  const el = document.getElementById('ley-countdown');
  if (el) {
    const deadline = new Date(el.dataset.deadline || '2026-12-01T00:00:00-03:00').getTime();
    const start = new Date(el.dataset.start || '2024-12-13T00:00:00-03:00').getTime();
    const progress = document.getElementById('ley-progress');
    const set = (unit: string, val: number) => {
      const node = el.querySelector(`[data-unit="${unit}"]`);
      if (node) node.textContent = String(val).padStart(2, '0');
    };
    const tick = () => {
      const now = Date.now();
      const diff = deadline - now;
      if (diff <= 0) {
        set('dias', 0); set('horas', 0); set('min', 0);
        if (progress) progress.style.width = '100%';
        return;
      }
      const dias = Math.floor(diff / 86400000);
      const horas = Math.floor((diff % 86400000) / 3600000);
      const min = Math.floor((diff % 3600000) / 60000);
      set('dias', dias); set('horas', horas); set('min', min);
      if (progress) {
        const pct = Math.min(100, Math.max(0, ((now - start) / (deadline - start)) * 100));
        progress.style.width = pct.toFixed(1) + '%';
      }
    };
    tick();
    setInterval(tick, 60000);
  }

  // Desplegable "¿Qué es la Ley 21.719?"
  const saberBtn = document.getElementById('ley-saber-btn');
  const panel = document.getElementById('ley-explainer');
  const chevron = document.getElementById('ley-chevron');
  saberBtn?.addEventListener('click', () => {
    const open = panel?.classList.toggle('open');
    saberBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
    chevron?.classList.toggle('rotate-180', open);
  });
</script>

<style>
  .font-sn { font-family: 'Poppins', 'Geist', system-ui, sans-serif; }
  /* Acordeón: anima la altura de 0fr a 1fr sin saltos */
  .ley-panel.open { grid-template-rows: 1fr; }

  /* Glows del fondo flotando suavemente (igual que el Hero) */
  @keyframes float-a {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50%      { transform: translate(-30px, 20px) scale(1.08); }
  }
  @keyframes float-b {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50%      { transform: translate(25px, -25px) scale(1.06); }
  }
  .animate-float-slow   { animation: float-a 12s ease-in-out infinite; }
  .animate-float-slower { animation: float-b 16s ease-in-out infinite; }
  @media (prefers-reduced-motion: reduce) {
    .animate-float-slow,
    .animate-float-slower { animation: none; }
  }

  /* Estrella: nace pequeña en el centro y se expande rápido con un rebote */
  .ley-star {
    transform: scale(0);
    transform-origin: center;
    animation: ley-star-pop 0.7s cubic-bezier(0.34, 1.56, 0.64, 1) 0.15s forwards;
    filter: drop-shadow(0 6px 16px rgba(98, 216, 78, 0.45));
  }
  @keyframes ley-star-pop {
    0%   { transform: scale(0) rotate(-45deg); }
    100% { transform: scale(1) rotate(0deg); }
  }
  /* Balanceo suave continuo (arranca cuando termina el pop) */
  .ley-star svg {
    animation: ley-star-bob 4.5s ease-in-out 1s infinite;
  }
  @keyframes ley-star-bob {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50%      { transform: translateY(-6px) rotate(5deg); }
  }
  @media (prefers-reduced-motion: reduce) {
    .ley-star { animation: none; transform: scale(1); }
    .ley-star svg { animation: none; }
  }
</style>
