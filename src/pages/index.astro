---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import Ley21719 from '../components/Ley21719.astro';


import Testimonials from '../components/Testimonios.astro'

;
// Aquí importaremos Services, Portfolio, etc. más adelante
---

<Layout
	title="SurCode | Software a Medida, Automatización con IA y Ley 21.719 en Chile"
	description="Fábrica de software en Chile: desarrollo a medida, automatización e integraciones con IA controlada y cumplimiento de la Ley 21.719. Agenda un diagnóstico gratis."
>

	<!-- Intro de carga estilo ServiceNow: estrella que nace al centro, se expande y revela la página -->
	<div id="intro-splash" aria-hidden="true">
		<svg viewBox="-8 -8 116 116" class="intro-star">
			<defs>
				<linearGradient id="introStarFill" x1="0" y1="0" x2="0" y2="1">
					<stop offset="0" stop-color="#84ef67"/>
					<stop offset="0.5" stop-color="#62d84e"/>
					<stop offset="1" stop-color="#3aab2b"/>
				</linearGradient>
			</defs>
			<path d="M50,7 L61.76,35.82 L92.8,38.1 L69.02,58.18 L76.45,88.4 L50,72 L23.55,88.4 L30.98,58.18 L7.2,38.1 L38.24,35.82 Z"
				  fill="url(#introStarFill)" stroke="#2f7d1f" stroke-width="5.5" stroke-linejoin="round"/>
		</svg>
	</div>

	<!-- FAQ estructurado (Ley 21.719) para rich results en Google -->
	<script type="application/ld+json" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "FAQPage",
		"mainEntity": [
			{
				"@type": "Question",
				"name": "¿Qué es la Ley 21.719?",
				"acceptedAnswer": {
					"@type": "Answer",
					"text": "Es la nueva Ley de Protección de Datos Personales de Chile (dic 2024). Reemplaza la ley de 1999 y, por primera vez, crea una Agencia (APDP) que puede fiscalizar y multar. Está inspirada en el GDPR europeo."
				}
			},
			{
				"@type": "Question",
				"name": "¿A quién aplica la Ley 21.719?",
				"acceptedAnswer": {
					"@type": "Answer",
					"text": "A cualquier empresa, grande o PYME, que recopile o use datos personales: nombres, RUT, correos, datos de salud, financieros o de RRHH. Si tienes una base de clientes, te aplica."
				}
			},
			{
				"@type": "Question",
				"name": "¿Qué exige la Ley 21.719?",
				"acceptedAnswer": {
					"@type": "Answer",
					"text": "Pedir consentimiento explícito para usar los datos, permitir que las personas accedan, corrijan o eliminen sus datos, registrar cómo tratas los datos, avisar filtraciones en 72 horas y aplicar medidas de seguridad reales."
				}
			},
			{
				"@type": "Question",
				"name": "¿Qué pasa si no cumplo la Ley 21.719?",
				"acceptedAnswer": {
					"@type": "Answer",
					"text": "Multas de hasta 20.000 UTM (aproximadamente $1.400 millones) o hasta el 4% de las ventas anuales en caso de reincidencia. La fecha límite para estar en regla es el 1 de diciembre de 2026."
				}
			}
		]
	})} />

	<main class="relative z-10">
        <Hero />
        <Ley21719 />
        <Services />
        <Testimonials />
        


	</main>
</Layout>

<style>
	/* Overlay a pantalla completa que se desvanece tras el pop de la estrella */
	#intro-splash {
		position: fixed;
		inset: 0;
		z-index: 200;
		display: flex;
		align-items: center;
		justify-content: center;
		background: transparent;
		pointer-events: none;
		animation: intro-fade 0.5s ease-in forwards;
	}
	.intro-star {
		width: clamp(110px, 22vw, 200px);
		height: clamp(110px, 22vw, 200px);
		transform-origin: center;
		filter: drop-shadow(0 0 40px rgba(98, 216, 78, 0.55));
		animation: intro-grow 0.5s ease-in forwards;
	}
	/* Parte pequeña en el centro, se agranda de forma continua y se desvanece */
	@keyframes intro-grow {
		0%   { transform: scale(0.12); opacity: 1; }
		65%  { transform: scale(7); opacity: 1; }
		100% { transform: scale(20); opacity: 0; }
	}
	@keyframes intro-fade {
		0%      { opacity: 1; }
		65%     { opacity: 1; }
		100%    { opacity: 0; visibility: hidden; }
	}
	@media (prefers-reduced-motion: reduce) {
		#intro-splash { display: none; }
	}
</style>

<script>
	// Quita el overlay del DOM cuando termina el fade (libera clics y scroll)
	const splash = document.getElementById('intro-splash');
	if (splash) {
		const remove = () => splash.remove();
		splash.addEventListener('animationend', (e) => {
			if (e.target === splash) remove();
		});
		// Respaldo por si la animación no dispara el evento
		setTimeout(remove, 1800);
	}
</script>