---
import Layout from '../layouts/Layout.astro';

// Mismo endpoint Formspree que ya usabas (sin backend, compatible con Astro estático)
const FORMSPREE = "https://formspree.io/f/mbdagglk";

// ─────────────────────────────────────────────────────────────────────────────
// PENDIENTE ANTI-SPAM (configuración en el panel de Formspree, NO en código):
//   1. Entrar a formspree.io → formulario "mbdagglk" → Settings.
//   2. Activar "Spam filtering" (filtro de contenido).
//   3. Si el plan lo permite, activar también "reCAPTCHA".
// El honeypot (_gotcha) ya está implementado más abajo en el formulario.
// Siguiente escalón si se cuela spam: integrar Cloudflare Turnstile (gratis).
// ─────────────────────────────────────────────────────────────────────────────

const recursos = [
  {
    title: "Cumple la Ley 21.719",
    desc: "Prepara tu negocio para la nueva Ley de Protección de Datos antes de la fiscalización de diciembre de 2026.",
    href: "/#ley-21719",
    icon: "shield",
  },
  {
    title: "Pon la IA a trabajar",
    desc: "Automatizaciones, agentes e integraciones de IA que ejecutan tareas reales por ti las 24 horas.",
    href: "/#servicios",
    icon: "chip",
  },
  {
    title: "Automatiza tu negocio",
    desc: "Conectamos tus apps y procesos para que el trabajo repetitivo deje de consumir tu tiempo.",
    href: "/#servicios",
    icon: "bolt",
  },
  {
    title: "Resuelve por WhatsApp",
    desc: "¿Apurado? Escríbenos directo y un experto te responde en horario hábil, de lunes a domingo.",
    href: "#",
    wa: "NTY5NTgxMDA0Mjg=",
    icon: "chat",
  },
];
---

<Layout
  title="Contacto | SurCode — Habla con un experto"
  description="Cuéntanos tu proyecto: software a medida, automatización con IA, integraciones o cumplimiento de la Ley 21.719 en Chile. Respuesta rápida por WhatsApp."
>
  <section class="relative min-h-screen pt-32 pb-24 bg-[#0a0f1d] overflow-hidden">
    <!-- Glows de acento -->
    <div class="absolute -top-24 -right-24 w-96 h-96 bg-[#62d84e]/10 blur-[120px] rounded-full pointer-events-none"></div>
    <div class="absolute -bottom-24 -left-24 w-96 h-96 bg-cyan-500/10 blur-[120px] rounded-full pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-6 relative z-10">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-start">

        <!-- Columna izquierda: formulario (tarjeta clara) -->
        <div class="bg-slate-100 rounded-[2rem] p-8 md:p-12 shadow-2xl">
          <h1 class="font-sn text-3xl md:text-4xl lg:text-5xl font-extrabold -tracking-[0.02em] text-[#0a0f1d] leading-[1.05] mb-4">
            Habla con un experto
          </h1>
          <p class="text-slate-600 mb-8">
            Cuéntanos qué necesitas y diseñamos contigo la solución a medida para tu negocio.
          </p>

          <form id="contact-form" action={FORMSPREE} method="POST" class="space-y-5">
            <input type="hidden" name="_subject" value="Nuevo contacto desde surcode.cl" />

            <!-- Honeypot anti-spam: invisible para humanos; los bots lo rellenan y el envío se descarta -->
            <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" aria-hidden="true" class="hidden" />

            <div id="form-content" class="space-y-5 transition-opacity duration-500">
              <!-- Email -->
              <div>
                <label class="block text-xs font-semibold text-slate-500 mb-1.5">Correo electrónico empresarial *</label>
                <input type="email" name="email" required placeholder="tu@empresa.cl"
                  class="w-full bg-white border border-slate-300 rounded-xl px-4 py-3 text-slate-900 placeholder:text-slate-400 focus:outline-none focus:border-[#62d84e] focus:ring-2 focus:ring-[#62d84e]/20 transition-all" />
              </div>

              <!-- Nombre / Apellido -->
              <div class="grid sm:grid-cols-2 gap-4">
                <div>
                  <label class="block text-xs font-semibold text-slate-500 mb-1.5">Nombre *</label>
                  <input type="text" name="nombre" required placeholder="Juan"
                    class="w-full bg-white border border-slate-300 rounded-xl px-4 py-3 text-slate-900 placeholder:text-slate-400 focus:outline-none focus:border-[#62d84e] focus:ring-2 focus:ring-[#62d84e]/20 transition-all" />
                </div>
                <div>
                  <label class="block text-xs font-semibold text-slate-500 mb-1.5">Apellido *</label>
                  <input type="text" name="apellido" required placeholder="Pérez"
                    class="w-full bg-white border border-slate-300 rounded-xl px-4 py-3 text-slate-900 placeholder:text-slate-400 focus:outline-none focus:border-[#62d84e] focus:ring-2 focus:ring-[#62d84e]/20 transition-all" />
                </div>
              </div>

              <!-- Compañía / Teléfono -->
              <div class="grid sm:grid-cols-2 gap-4">
                <div>
                  <label class="block text-xs font-semibold text-slate-500 mb-1.5">Empresa</label>
                  <input type="text" name="empresa" placeholder="Nombre de tu empresa"
                    class="w-full bg-white border border-slate-300 rounded-xl px-4 py-3 text-slate-900 placeholder:text-slate-400 focus:outline-none focus:border-[#62d84e] focus:ring-2 focus:ring-[#62d84e]/20 transition-all" />
                </div>
                <div>
                  <label class="block text-xs font-semibold text-slate-500 mb-1.5">Teléfono *</label>
                  <input type="tel" name="telefono" required placeholder="+56 9 1234 5678"
                    class="w-full bg-white border border-slate-300 rounded-xl px-4 py-3 text-slate-900 placeholder:text-slate-400 focus:outline-none focus:border-[#62d84e] focus:ring-2 focus:ring-[#62d84e]/20 transition-all" />
                </div>
              </div>

              <!-- Rubro -->
              <div>
                <label class="block text-xs font-semibold text-slate-500 mb-1.5">Rubro</label>
                <div class="relative">
                  <select name="rubro"
                    class="w-full appearance-none bg-white border border-slate-300 rounded-xl px-4 py-3 text-slate-900 focus:outline-none focus:border-[#62d84e] focus:ring-2 focus:ring-[#62d84e]/20 transition-all cursor-pointer">
                    <option value="" selected>Selecciona tu rubro</option>
                    <option>Comercio / Retail</option>
                    <option>Salud</option>
                    <option>Finanzas / Fintech</option>
                    <option>Educación</option>
                    <option>Servicios profesionales</option>
                    <option>Inmobiliaria / Construcción</option>
                    <option>Otro</option>
                  </select>
                  <svg class="w-5 h-5 text-slate-400 absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
                </div>
              </div>

              <!-- Servicio de interés -->
              <div>
                <label class="block text-xs font-semibold text-slate-500 mb-1.5">Servicio de interés *</label>
                <div class="relative">
                  <select name="servicio" required
                    class="w-full appearance-none bg-white border border-slate-300 rounded-xl px-4 py-3 text-slate-900 focus:outline-none focus:border-[#62d84e] focus:ring-2 focus:ring-[#62d84e]/20 transition-all cursor-pointer">
                    <option value="" disabled selected>Selecciona un servicio</option>
                    <option>Cumplimiento Ley 21.719</option>
                    <option>Automatizaciones a medida</option>
                    <option>Integraciones de IA</option>
                    <option>Sistema de gestión empresarial</option>
                    <option>E-commerce / Tienda online</option>
                    <option>Seguridad de datos</option>
                    <option>Otro</option>
                  </select>
                  <svg class="w-5 h-5 text-slate-400 absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
                </div>
              </div>

              <!-- Me gustaría -->
              <div>
                <label class="block text-xs font-semibold text-slate-500 mb-1.5">Me gustaría *</label>
                <div class="relative">
                  <select name="objetivo" required
                    class="w-full appearance-none bg-white border border-slate-300 rounded-xl px-4 py-3 text-slate-900 focus:outline-none focus:border-[#62d84e] focus:ring-2 focus:ring-[#62d84e]/20 transition-all cursor-pointer">
                    <option value="" disabled selected>¿Qué buscas?</option>
                    <option>Solicitar una propuesta</option>
                    <option>Agendar una reunión</option>
                    <option>Pedir un diagnóstico gratis</option>
                    <option>Hacer una consulta general</option>
                  </select>
                  <svg class="w-5 h-5 text-slate-400 absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" /></svg>
                </div>
              </div>

              <!-- Mensaje -->
              <div>
                <label class="block text-xs font-semibold text-slate-500 mb-1.5">Mensaje</label>
                <textarea name="mensaje" rows="4" placeholder="Cuéntanos sobre tu proyecto..."
                  class="w-full bg-white border border-slate-300 rounded-xl px-4 py-3 text-slate-900 placeholder:text-slate-400 focus:outline-none focus:border-[#62d84e] focus:ring-2 focus:ring-[#62d84e]/20 transition-all resize-none"></textarea>
              </div>

              <button type="submit" id="submit-button"
                class="w-full inline-flex items-center justify-center gap-2 bg-[#62d84e] hover:bg-[#74e85f] text-[#04101f] font-bold py-4 rounded-full transition-all hover:scale-[1.02] active:scale-95 shadow-[0_10px_30px_rgba(98,216,78,0.35)] disabled:opacity-50 disabled:cursor-not-allowed">
                <span id="button-text">Enviar mensaje</span>
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
              </button>

              <p class="text-xs text-slate-400 text-center">Al enviar aceptas que SurCode te contacte sobre tu solicitud.</p>
            </div>

            <!-- Éxito -->
            <div id="success-message" class="hidden flex-col items-center text-center py-12 space-y-4">
              <div class="w-20 h-20 bg-[#62d84e]/20 rounded-full flex items-center justify-center">
                <svg class="w-10 h-10 text-[#3a9e2c]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              </div>
              <h3 class="text-2xl font-extrabold text-[#0a0f1d]">¡Mensaje enviado!</h3>
              <p class="text-slate-600 max-w-xs">Recibimos tu solicitud. Un experto de SurCode te contactará a la brevedad.</p>
              <button type="button" id="reset-form" class="text-sm font-bold text-[#3a9e2c] hover:underline">Enviar otro mensaje</button>
            </div>
          </form>
        </div>

        <!-- Columna derecha: recursos -->
        <div class="lg:pt-4">
          <h2 class="font-sn text-3xl md:text-4xl lg:text-5xl font-extrabold -tracking-[0.02em] text-white leading-[1.05] mb-10">
            Consigue los recursos<br>que necesitas
          </h2>

          <div class="grid sm:grid-cols-2 gap-x-10 gap-y-12">
            {recursos.map((r) => (
              <a href={r.href} data-wa={r.wa} class="group block">
                <div class="text-[#62d84e] mb-4">
                  <svg class="w-9 h-9" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6">
                    {r.icon === 'shield' && <><path stroke-linecap="round" stroke-linejoin="round" d="M12 3l7 3v5c0 4.5-3 8.5-7 10-4-1.5-7-5.5-7-10V6l7-3z" /><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4" /></>}
                    {r.icon === 'chip' && <><rect x="7" y="7" width="10" height="10" rx="2" /><path stroke-linecap="round" d="M9 3v2M12 3v2M15 3v2M9 19v2M12 19v2M15 19v2M3 9h2M3 12h2M3 15h2M19 9h2M19 12h2M19 15h2" /></>}
                    {r.icon === 'bolt' && <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />}
                    {r.icon === 'chat' && <path stroke-linecap="round" stroke-linejoin="round" d="M8 10h8M8 14h5M21 12a8 8 0 01-11.6 7.14L4 20l1.14-4.4A8 8 0 1121 12z" />}
                  </svg>
                </div>
                <h3 class="text-xl font-bold text-white mb-2 group-hover:text-[#62d84e] transition-colors">{r.title}</h3>
                <p class="text-slate-400 text-sm leading-relaxed mb-4">{r.desc}</p>
                <svg class="w-6 h-6 text-white group-hover:text-[#62d84e] group-hover:translate-x-1 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
              </a>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const formContent = document.getElementById('form-content');
  const successMessage = document.getElementById('success-message');
  const submitButton = document.getElementById('submit-button') as HTMLButtonElement;
  const buttonText = document.getElementById('button-text');
  const resetButton = document.getElementById('reset-form');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Honeypot: si el campo trampa viene relleno, es un bot. Fingimos éxito y no enviamos.
    const honeypot = form.querySelector('input[name="_gotcha"]') as HTMLInputElement | null;
    if (honeypot && honeypot.value) {
      formContent?.classList.add('hidden');
      successMessage?.classList.remove('hidden');
      successMessage?.classList.add('flex');
      return;
    }

    if (submitButton) submitButton.disabled = true;
    if (buttonText) buttonText.innerText = "Enviando...";

    try {
      const response = await fetch(form.action, {
        method: form.method,
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });
      if (!response.ok) throw new Error('server');
      formContent?.classList.add('hidden');
      successMessage?.classList.remove('hidden');
      successMessage?.classList.add('flex');
      form.reset();
    } catch {
      alert('Hubo un error al enviar. Intenta de nuevo o escríbenos por WhatsApp.');
      if (submitButton) submitButton.disabled = false;
      if (buttonText) buttonText.innerText = "Enviar mensaje";
    }
  });

  resetButton?.addEventListener('click', () => {
    successMessage?.classList.add('hidden');
    successMessage?.classList.remove('flex');
    formContent?.classList.remove('hidden');
    if (submitButton) submitButton.disabled = false;
    if (buttonText) buttonText.innerText = "Enviar mensaje";
  });
</script>

<style>
  .font-sn { font-family: 'Poppins', 'Geist', system-ui, sans-serif; }
</style>
